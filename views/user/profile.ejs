    // ========== ФУНКЦИИ ДЛЯ ПРОСМОТРА МЕДИА ==========
    function openMediaModal(src, type) {
        const modal = document.getElementById('mediaModal');
        const modalImage = document.getElementById('modalImage');
        const modalVideo = document.getElementById('modalVideo');
        
        if (!modal) return;
        
        if (modalImage) modalImage.style.display = 'none';
        if (modalVideo) modalVideo.style.display = 'none';
        
        if (type === 'image') {
            if (modalImage) {
                modalImage.src = src;
                modalImage.style.display = 'block';
            }
        } else if (type === 'video') {
            if (modalVideo) {
                modalVideo.src = src;
                modalVideo.style.display = 'block';
                modalVideo.load();
                modalVideo.setAttribute('controls', 'true');
            }
        }
        
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }

    function closeMediaModal() {
        const modal = document.getElementById('mediaModal');
        const modalVideo = document.getElementById('modalVideo');
        
        if (modal) modal.style.display = 'none';
        if (modalVideo) {
            modalVideo.pause();
            modalVideo.src = '';
        }
        document.body.style.overflow = '';
    }

    function applyVideoThumbnails(root = document) {
        const videos = root.querySelectorAll ? root.querySelectorAll('.review-video-thumb') : [];
        videos.forEach((video) => {
            if (video.dataset.posterReady === '1') return;
            video.dataset.posterReady = '1';
            const setPoster = () => {
                try {
                    const canvas = document.createElement('canvas');
                    canvas.width = video.videoWidth || 320;
                    canvas.height = video.videoHeight || 180;
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                    video.poster = canvas.toDataURL('image/jpeg', 0.75);
                } catch (e) {
                    console.warn('Poster generation failed', e);
                }
            };
            if (video.readyState >= 2) {
                setPoster();
            } else {
                video.addEventListener('loadeddata', setPoster, { once: true });
            }
        });
    }


    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeMediaModal();
        }
    });

    applyVideoThumbnails();
    const profileObserver = new MutationObserver(() => applyVideoThumbnails());
    profileObserver.observe(document.body, { childList: true, subtree: true });

    document.addEventListener('DOMContentLoaded', function() {
        const feedVideos = document.querySelectorAll('#feed .media-preview video');
        feedVideos.forEach(video => {
            video.setAttribute('muted', 'true');
            video.addEventListener('mouseenter', function() {
                this.play().catch(e => console.log('Auto-play prevented:', e));
            });
            video.addEventListener('mouseleave', function() {
                this.pause();
                this.currentTime = 0;
            });
        });
        
        const reviewVideos = document.querySelectorAll('#reviews .media-preview video');
        reviewVideos.forEach(video => {
            video.setAttribute('muted', 'true');
            video.addEventListener('mouseenter', function() {
                this.play().catch(e => console.log('Auto-play prevented'));
            });
            video.addEventListener('mouseleave', function() {
                this.pause();
                this.currentTime = 0;
            });
        });
    });

    // ========== УВЕДОМЛЕНИЯ ==========
    document.querySelectorAll('.notification-item').forEach(item => {
        item.addEventListener('click', async (e) => {
            if (e.target.closest('.delete-notification')) return;
            
            const notificationId = item.dataset.id;
            if (notificationId && item.classList.contains('unread')) {
                try {
                    await fetch(`/user/notifications/read/${notificationId}`, { method: 'POST' });
                    item.classList.remove('unread');
                    item.style.background = '#fff';
                    item.style.borderColor = '#e2e8f0';
                } catch (error) {
                    console.error('Mark as read error:', error);
                }
            }
        });
    });

    document.querySelectorAll('.delete-notification').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            e.stopPropagation();
            const notificationId = btn.dataset.id;
            const item = btn.closest('.notification-item');
            
            if (notificationId && confirm('Удалить уведомление?')) {
                try {
                    const response = await fetch(`/user/notifications/delete/${notificationId}`, { method: 'POST' });
                    const data = await response.json();
                    if (data.success) {
                        item.style.transition = 'opacity 0.3s';
                        item.style.opacity = '0';
                        setTimeout(() => item.remove(), 300);
                        
                        const remaining = document.querySelectorAll('.notification-item').length;
                        if (remaining === 0) {
                            location.reload();
                        }
                    }
                } catch (error) {
                    console.error('Delete notification error:', error);
                }
            }
        });
    });

    const clearAllBtn = document.getElementById('clearAllNotifications');
    if (clearAllBtn) {
        clearAllBtn.addEventListener('click', async () => {
            if (confirm('Удалить все уведомления?')) {
                try {
                    const response = await fetch('/user/notifications/clear', { method: 'POST' });
                    const data = await response.json();
                    if (data.success) {
                        location.reload();
                    }
                } catch (error) {
                    console.error('Clear all error:', error);
                }
            }
        });
    }
    </script>
