        <script>
        function normalizeMediaList(value) {
            if (Array.isArray(value)) return value;
            if (!value || value === '[]' || value === 'null') return [];
            try {
                const parsed = JSON.parse(value);
                return Array.isArray(parsed) ? parsed : [];
            } catch (e) {
                return [];
            }
        }

    function previewFile(input) {
        const file = input.files[0];
        if (!file) return;

        const container = input.parentElement;
        let preview = container.querySelector('.preview-img');
        const svg = container.querySelector('svg');
        const span = container.querySelector('span');
        
        const fileType = file.type;
        const fileUrl = URL.createObjectURL(file);

        if (preview) {
            preview.remove();
        }

        if (fileType.startsWith('image/')) {
            preview = document.createElement('img');
        } else {
            preview = document.createElement('video');
            preview.muted = true;
            preview.autoplay = true;
            preview.loop = true;
            preview.playsInline = true;
        }
        
        preview.className = 'preview-img';
        preview.src = fileUrl;
        preview.style.display = 'block';
        container.appendChild(preview);
        
        if (preview.tagName === 'VIDEO') {
            preview.load();
        }
        
        if (svg) svg.style.display = 'none';
        if (span) span.style.display = 'none';
    }

    // ========== ПЕРЕКЛЮЧЕНИЕ ВКЛАДОК ==========
    function switchTab(tabId) {
        document.querySelectorAll('.menu-btn').forEach(btn => btn.classList.remove('active'));
        const targetBtn = document.querySelector(`.menu-btn[data-tab="${tabId}"]`);
        if (targetBtn) targetBtn.classList.add('active');
        
        document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.remove('active'));
        const targetPane = document.getElementById(tabId);
        if (targetPane) targetPane.classList.add('active');
        
        history.replaceState(null, null, '?tab=' + tabId);
    }

    document.querySelectorAll('.menu-btn[data-tab]').forEach(btn => {
        btn.addEventListener('click', (e) => {
            e.preventDefault();
            switchTab(btn.getAttribute('data-tab'));
        });
    });

    window.addEventListener('load', () => {
        const urlParams = new URLSearchParams(window.location.search);
        const tab = urlParams.get('tab');
        if (tab && ['profile', 'favorites', 'going', 'reviews', 'proposals', 'feed', 'notifications'].includes(tab)) {
            switchTab(tab);
        } else {
            switchTab('profile');
        }
        
        // Запускаем все функции после загрузки
        setTimeout(() => {
            initLikes();
            initDeleteReviews();
            initDeleteProposals();
        }, 500);
    });

    // ========== ФУНКЦИЯ ДЛЯ УВЕДОМЛЕНИЙ ==========
    function showNotification(message, type = 'success') {
        const existingNotification = document.querySelector('.custom-notification');
        if (existingNotification) existingNotification.remove();
        
        let bgColor = '#635bff';
        
        const notification = document.createElement('div');
        notification.className = `custom-notification ${type}`;
        notification.innerHTML = `
            <div style="
                position: fixed;
                top: 30px;
                right: 30px;
                background: ${bgColor};
                color: #fff;
                padding: 14px 24px;
                border-radius: 16px;
                font-weight: 600;
                font-family: 'Manrope', sans-serif;
                font-size: 14px;
                z-index: 10000;
                box-shadow: 0 10px 25px rgba(99, 91, 255, 0.3);
                animation: slideInRight 0.3s ease;
                display: flex;
                align-items: center;
                gap: 10px;
            ">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                    ${type === 'success' 
                        ? '<polyline points="20 6 9 17 4 12"></polyline>'
                        : '<circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line>'
                    }
                </svg>
                ${message}
            </div>
        `;
        
        if (!document.querySelector('#notification-styles')) {
            const style = document.createElement('style');
            style.id = 'notification-styles';
            style.textContent = `
                @keyframes slideInRight {
                    from { transform: translateX(100%); opacity: 0; }
                    to { transform: translateX(0); opacity: 1; }
                }
                @keyframes slideOutRight {
                    from { transform: translateX(0); opacity: 1; }
                    to { transform: translateX(100%); opacity: 0; }
                }
            `;
            document.head.appendChild(style);
        }
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.style.animation = 'slideOutRight 0.3s ease';
            setTimeout(() => notification.remove(), 300);
        }, 3000);
    }

    // ========== ФУНКЦИИ ДЛЯ ЖАЛОБ ==========
    let currentReportReviewId = null;
    let isSubmitting = false;

    async function openReportModal(reviewId) {
        const reportBtn = document.querySelector(`.btn-report-review[data-id="${reviewId}"]`);
        const alreadyReported = reportBtn && reportBtn.hasAttribute('data-reported');
        
        if (alreadyReported) {
            const modal = document.getElementById('reportModal');
            const errorDiv = document.getElementById('reportError');
            const submitBtn = document.querySelector('.report-btn-submit');
            
            if (modal) {
                const successDiv = document.getElementById('reportSuccess');
                if (successDiv) successDiv.style.display = 'none';
                
                if (errorDiv) {
                    errorDiv.style.display = 'block';
                    errorDiv.textContent = 'Вы уже жаловались на этот отзыв';
                    errorDiv.style.color = '#ef4444';
                    errorDiv.style.background = '#fee2e2';
                    errorDiv.style.padding = '12px';
                    errorDiv.style.borderRadius = '12px';
                    errorDiv.style.marginBottom = '20px';
                }
                
                if (submitBtn) submitBtn.disabled = true;
                modal.classList.add('active');
            }
            return;
        }
        
        currentReportReviewId = reviewId;
        const modal = document.getElementById('reportModal');
        const reasonSelect = document.getElementById('reportReason');
        const reasonText = document.getElementById('reportReasonText');
        const errorDiv = document.getElementById('reportError');
        const successDiv = document.getElementById('reportSuccess');
        const submitBtn = document.querySelector('.report-btn-submit');
        
        if (modal) {
            reasonSelect.value = 'Спам или реклама';
            reasonText.value = '';
            reasonText.style.display = 'none';
            if (errorDiv) errorDiv.style.display = 'none';
            if (successDiv) successDiv.style.display = 'none';
            if (submitBtn) submitBtn.disabled = false;
            modal.classList.add('active');
        }
    }

    window.closeReportModal = function() {
        const modal = document.getElementById('reportModal');
        if (modal) modal.classList.remove('active');
        currentReportReviewId = null;
        isSubmitting = false;
        
        const submitBtn = document.querySelector('.report-btn-submit');
        const errorDiv = document.getElementById('reportError');
        const successDiv = document.getElementById('reportSuccess');
        
        if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'Отправить жалобу';
        }
        if (errorDiv) errorDiv.style.display = 'none';
        if (successDiv) successDiv.style.display = 'none';
    }

    window.submitReport = async function() {
        if (!currentReportReviewId) return;
        if (isSubmitting) return;
        
        const reportBtn = document.querySelector(`.btn-report-review[data-id="${currentReportReviewId}"]`);
        if (reportBtn && reportBtn.hasAttribute('data-reported')) {
            const errorDiv = document.getElementById('reportError');
            if (errorDiv) {
                errorDiv.style.display = 'block';
                errorDiv.textContent = 'Вы уже жаловались на этот отзыв';
                errorDiv.style.color = '#ef4444';
                errorDiv.style.background = '#fee2e2';
                errorDiv.style.padding = '12px';
                errorDiv.style.borderRadius = '12px';
                errorDiv.style.marginBottom = '20px';
            }
            return;
        }
        
        isSubmitting = true;
        const submitBtn = document.querySelector('.report-btn-submit');
        const errorDiv = document.getElementById('reportError');
        const successDiv = document.getElementById('reportSuccess');
        
        if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Отправка...';
        }
        
        const reasonSelect = document.getElementById('reportReason');
        const reasonText = document.getElementById('reportReasonText');
        let reason = reasonSelect.value;
        
        if (reason === 'Другое' && reasonText.value.trim()) {
            reason = reasonText.value.trim();
        }
        
        try {
            const response = await fetch('/user/reviews/report', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ reviewId: currentReportReviewId, reason: reason })
            });
            
            const data = await response.json();
            
            if (data.success) {
                if (reportBtn) {
                    reportBtn.setAttribute('data-reported', 'true');
                    reportBtn.style.opacity = '0.5';
                    reportBtn.style.cursor = 'not-allowed';
                    reportBtn.title = 'Жалоба уже отправлена';
                }
                
                if (successDiv) {
                    successDiv.style.display = 'block';
                    successDiv.textContent = 'Жалоба отправлена на модерацию';
                    successDiv.style.color = '#16a34a';
                    successDiv.style.background = '#dcfce7';
                    successDiv.style.padding = '12px';
                    successDiv.style.borderRadius = '12px';
                    successDiv.style.marginBottom = '20px';
                }
                
                if (errorDiv) errorDiv.style.display = 'none';
                
                setTimeout(() => {
                    closeReportModal();
                    showNotification('Жалоба отправлена на модерацию', 'success');
                }, 2000);
            } else {
                if (errorDiv) {
                    errorDiv.style.display = 'block';
                    errorDiv.textContent = data.error || 'Ошибка при отправке жалобы';
                    errorDiv.style.color = '#ef4444';
                    errorDiv.style.background = '#fee2e2';
                    errorDiv.style.padding = '12px';
                    errorDiv.style.borderRadius = '12px';
                    errorDiv.style.marginBottom = '20px';
                }
                
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Отправить жалобу';
                }
            }
        } catch (error) {
            console.error('Report error:', error);
            if (errorDiv) {
                errorDiv.style.display = 'block';
                errorDiv.textContent = 'Ошибка сервера. Попробуйте позже.';
                errorDiv.style.color = '#ef4444';
                errorDiv.style.background = '#fee2e2';
                errorDiv.style.padding = '12px';
                errorDiv.style.borderRadius = '12px';
                errorDiv.style.marginBottom = '20px';
            }
            
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Отправить жалобу';
            }
        } finally {
            isSubmitting = false;
        }
    }

    // ========== ЛАЙКИ ==========
    function initLikes() {
        const likeButtons = document.querySelectorAll('.btn-like-review');
        console.log('Инициализация лайков, кнопок:', likeButtons.length);
        
        likeButtons.forEach(button => {
            // Удаляем старые слушатели, если они есть (через замену элемента)
            const newButton = button.cloneNode(true);
            button.parentNode.replaceChild(newButton, button);
            
            newButton.addEventListener('click', async function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                const reviewId = this.getAttribute('data-id');
                console.log('Клик по лайку, ID:', reviewId);
                if (!reviewId) return;
                
                const likeBtn = this;
                const likesSpan = likeBtn.querySelector('span');
                const svg = likeBtn.querySelector('svg');
                
                try {
                    const response = await fetch('/user/reviews/like/' + reviewId, {
                        method: 'POST'
                    });
                    
                    const data = await response.json();
                    console.log('Ответ сервера по лайку:', data);
                    
                    if (data.success) {
                        if (likesSpan) likesSpan.textContent = data.likes;
                        if (data.liked) {
                            likeBtn.classList.add('liked');
                            if (svg) {
                                svg.setAttribute('fill', '#ef4444');
                                svg.setAttribute('stroke', '#ef4444');
                            }
                        } else {
                            likeBtn.classList.remove('liked');
                            if (svg) {
                                svg.setAttribute('fill', 'none');
                                svg.setAttribute('stroke', '#94a3b8');
                            }
                        }
                    } else {
                        alert('Ошибка: ' + (data.error || 'Неизвестная ошибка'));
                    }
                } catch (error) {
                    console.error('Like error:', error);
                    alert('Ошибка сервера при попытке поставить лайк');
                }
            });
        });
    }

    // ========== УДАЛЕНИЕ ОТЗЫВОВ ==========
    function initDeleteReviews() {
        const deleteButtons = document.querySelectorAll('.btn-delete-review');
        console.log('Найдено кнопок удаления отзывов:', deleteButtons.length);
        
        deleteButtons.forEach(btn => {
            const newBtn = btn.cloneNode(true);
            btn.parentNode.replaceChild(newBtn, btn);
            
            newBtn.addEventListener('click', async function(e) {
                e.preventDefault();
                e.stopPropagation();
                
                const reviewId = this.getAttribute('data-id');
                if (!reviewId) return;
                
                if (!confirm('Вы уверены, что хотите удалить этот отзыв?')) return;
                
                try {
                    const response = await fetch(`/user/reviews/delete/${reviewId}`, {
                        method: 'DELETE',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    
                    const data = await response.json();
                    
                    if (data.success) {
                        this.closest('.mini-card').remove();
                        showNotification('Отзыв удален', 'success');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        alert(data.error || 'Ошибка удаления');
                    }
                } catch (error) {
                    console.error('Delete error:', error);
                    alert('Ошибка сервера');
                }
            });
        });
    }

