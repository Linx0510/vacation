<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Лента отзывов - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .feed-container { max-width: 800px; margin: 40px auto; padding: 0 20px; }
        .feed-title { font-size: 32px; font-weight: 800; margin-bottom: 30px; color: #1e293b; }
        .review-card { 
            background: #fff; 
            border-radius: 24px; 
            padding: 30px; 
            margin-bottom: 25px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.04); 
            border: 1px solid #f1f5f9;
        }
        .review-header { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; }
        .user-avatar { 
            width: 50px; 
            height: 50px; 
            border-radius: 15px; 
            background: #635bff; 
            color: #fff; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            font-weight: 800;
            object-fit: cover;
        }
        .user-info h4 { margin: 0; font-size: 17px; font-weight: 800; color: #1e293b; }
        .user-info span { font-size: 13px; color: #94a3b8; }
        .review-content { font-size: 16px; line-height: 1.7; color: #475569; margin-bottom: 20px; }
        .review-media { display: flex; gap: 12px; flex-wrap: wrap; }
        .review-media img, .review-media video { width: 100%; max-width: 200px; border-radius: 16px; object-fit: cover; cursor: pointer; }
        .review-video-thumb { background: #111827; }
        
        .review-actions {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #f1f5f9;
        }
        .action-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            background: none;
            border: none;
            color: #64748b;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: 0.3s;
            padding: 8px 12px;
            border-radius: 10px;
        }
        .action-btn:hover { background: #f8fafc; color: #635bff; }
        .action-btn.liked { color: #635bff; }
        .action-btn.liked svg { fill: #635bff; stroke: #635bff; }
        .action-btn.report:hover { color: #ef4444; background: #fff1f1; }
        .event-link {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            text-decoration: none;
            color: #635bff;
            font-weight: 600;
            font-size: 13px;
            background: #f0f0ff;
            padding: 6px 14px;
            border-radius: 20px;
        }
        .empty-state { text-align: center; padding: 60px; color: #94a3b8; }

        /* Modal for Zoom */
        .zoom-modal {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9);
            z-index: 10000;
            align-items: center;
            justify-content: center;
            cursor: zoom-out;
        }
        .zoom-modal img, .zoom-modal video {
            max-width: 90%;
            max-height: 90%;
            border-radius: 12px;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
        }
    </style>
</head>
<body>
    <% function normalizeMediaList(value) {
        if (Array.isArray(value)) return value;
        if (!value || value === '[]' || value === 'null') return [];
        try {
            const parsed = JSON.parse(value);
            return Array.isArray(parsed) ? parsed : [];
        } catch (e) {
            return [];
        }
    } %>
    <%- include('../partials/header') %>

    <div class="zoom-modal" id="zoomModal" onclick="this.style.display='none'">
        <div id="zoomContent"></div>
    </div>

    <div class="feed-container">
        <h1 class="feed-title">Лента впечатлений</h1>
        
        <% if (typeof reviews !== 'undefined' && reviews && reviews.length > 0) { %>
            <% reviews.forEach(review => { %>
                <div class="review-card" data-id="<%= review.id %>">
                    <div class="review-header">
                        <% if (review.avatar) { %>
                            <img src="<%= review.avatar %>" class="user-avatar" style="object-fit: cover;">
                        <% } else { %>
                            <div class="user-avatar"><%= (review.first_name || 'U')[0].toUpperCase() %></div>
                        <% } %>
                        <div class="user-info">
                            <h4><%= review.first_name || 'Пользователь' %> <%= review.last_name || '' %></h4>
                            <span><%= new Date(review.created_at).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' }) %></span>
                        </div>
                    </div>
                    
                    <div class="review-content">
                        <%= review.comment %>
                    </div>

                    <% if (review.photos || review.videos) { %>
                        <div class="review-media">
                            <% const photos = normalizeMediaList(review.photos); if (photos.length > 0) { photos.forEach(photo => { %>
                                            <img src="<%= photo %>" onclick="zoomMedia(this.src, 'img')">
                                        <% }); } %>
                            <% const videos = normalizeMediaList(review.videos); if (videos.length > 0) { videos.forEach(video => { %>
                                            <video src="<%= video %>" class="review-video-thumb" onclick="zoomMedia(this.src, 'video')" muted preload="metadata"></video>
                                        <% }); } %>
                        </div>
                    <% } %>

                    <div class="review-actions">
                        <button class="action-btn btn-like-vk" data-id="<%= review.id %>">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                            </svg>
                            <span class="likes-count"><%= review.likes_count || 0 %></span>
                        </button>
                        
                        <% if (review.event_title) { %>
                            <a href="/events/<%= review.event_id %>" class="event-link">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                                    <circle cx="12" cy="10" r="3"></circle>
                                </svg>
                                <%= review.event_title %>
                            </a>
                        <% } %>

                        <button class="action-btn report" onclick="reportReview('<%= review.id %>')" style="margin-left: auto;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path>
                                <line x1="4" y1="22" x2="4" y2="15"></line>
                            </svg>
                            Жалоба
                        </button>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state">
                <p>Лента пока пуста</p>
                <p style="font-size: 14px;">Будьте первым, кто поделится отзывом о мероприятии!</p>
            </div>
        <% } %>
    </div>

    <script>
        function normalizeMediaList(value) {
            if (Array.isArray(value)) return value;
            if (!value || value === '[]' || value === 'null') return [];
            try {
                const parsed = JSON.parse(value);
                return Array.isArray(parsed) ? parsed : [];
            } catch (e) {
                return [];
            }
        }


        function applyVideoThumbnails(root = document) {
            const videos = root.querySelectorAll ? root.querySelectorAll('.review-video-thumb') : [];
            videos.forEach((video) => {
                if (video.dataset.posterReady === '1') return;
                video.dataset.posterReady = '1';
                const setPoster = () => {
                    try {
                        const canvas = document.createElement('canvas');
                        canvas.width = video.videoWidth || 320;
                        canvas.height = video.videoHeight || 180;
                        const ctx = canvas.getContext('2d');
                        ctx.drawImage(video, 0, 0, canvas.width, canvas.height);
                        video.poster = canvas.toDataURL('image/jpeg', 0.75);
                    } catch (e) {
                        console.warn('Poster generation failed', e);
                    }
                };
                if (video.readyState >= 2) {
                    setPoster();
                } else {
                    video.addEventListener('loadeddata', setPoster, { once: true });
                }
            });
        }

        applyVideoThumbnails();
        const feedObserver = new MutationObserver(() => applyVideoThumbnails());
        feedObserver.observe(document.body, { childList: true, subtree: true });

        function zoomMedia(src, type) {
            const modal = document.getElementById('zoomModal');
            const content = document.getElementById('zoomContent');
            if (type === 'img') {
                content.innerHTML = `<img src="${src}">`;
            } else {
                content.innerHTML = `<video src="${src}" controls autoplay></video>`;
            }
            modal.style.display = 'flex';
        }

        async function reportReview(reviewId) {
            const reason = prompt('Укажите причину жалобы:');
            if (!reason) return;

            try {
                const response = await fetch('/user/reviews/report', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reviewId: reviewId, reason: reason })
                });
                const data = await response.json();
                if (data.success) {
                    alert('Жалоба отправлена администратору. Спасибо за бдительность!');
                } else {
                    alert(data.error || 'Ошибка при отправке жалобы');
                }
            } catch (error) { 
                console.error(error);
                alert('Ошибка при отправке жалобы');
            }
        }

        // Лайки
        document.querySelectorAll('.btn-like-vk').forEach(btn => {
            btn.addEventListener('click', async () => {
                const reviewId = btn.dataset.id;
                try {
                    const response = await fetch(`/user/reviews/like/${reviewId}`, { method: 'POST' });
                    const data = await response.json();
                    if (data.success) {
                        const likesSpan = btn.querySelector('.likes-count');
                        likesSpan.textContent = data.likes;
                        if (data.liked) {
                            btn.classList.add('liked');
                        } else {
                            btn.classList.remove('liked');
                        }
                    }
                } catch (error) {
                    console.error('Like error:', error);
                }
            });
        });
    </script>

    <%- include('../partials/footer') %>
</body>
</html>