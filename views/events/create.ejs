<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Создать мероприятие - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .profile-layout { 
            display: grid; 
            grid-template-columns: 320px 1fr; 
            gap: 30px; 
            padding: 40px 0; 
            align-items: start;
        }
        .profile-sidebar { 
            background: #fff; 
            border-radius: 24px; 
            padding: 20px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.04); 
            position: sticky;
            top: 100px;
        }
        .profile-menu { display: flex; flex-direction: column; gap: 8px; }
        .menu-btn { 
            display: flex; 
            align-items: center; 
            gap: 12px; 
            padding: 14px 20px; 
            border-radius: 16px; 
            border: none; 
            background: none; 
            color: #64748b; 
            font-family: 'Manrope', sans-serif; 
            font-weight: 600; 
            font-size: 15px; 
            cursor: pointer; 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            text-align: left;
            width: 100%;
            box-sizing: border-box;
            text-decoration: none;
        }
        .menu-btn svg {
            width: 20px;
            height: 20px;
            stroke-width: 2px;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .menu-btn:hover { background: #f1f5f9; color: #1e293b; }
        .menu-btn:hover svg {
            transform: scale(1.2) rotate(5deg);
            color: #635bff;
        }
        .menu-btn.active { 
            background: #635bff; 
            color: #fff; 
            box-shadow: 0 4px 12px rgba(99, 91, 255, 0.25); 
        }
        .menu-btn.active svg {
            transform: scale(1.1);
            color: #fff;
        }
        .profile-content { 
            background: #fff; 
            border-radius: 24px; 
            padding: 40px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.04); 
            min-height: 500px;
            box-sizing: border-box;
        }
        .section-title { font-family: 'Manrope', sans-serif; font-size: 28px; font-weight: 800; margin-bottom: 25px; color: #1e293b; }
        
        .vk-form-group { margin-bottom: 24px; }
        .vk-label { display: block; font-size: 13px; font-weight: 800; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
        .vk-input { 
            width: 100%; 
            padding: 16px 20px; 
            border-radius: 16px; 
            border: 2px solid #f1f5f9; 
            background: #f8fafc; 
            font-family: 'Manrope', sans-serif; 
            font-size: 15px; 
            font-weight: 600; 
            color: #1e293b; 
            transition: 0.3s; 
            box-sizing: border-box;
        }
        .vk-input:focus { border-color: #635bff; background: #fff; outline: none; box-shadow: 0 0 0 4px rgba(99, 91, 255, 0.1); }
        
        .btn-submit-vk { 
            background: #635bff; 
            color: #fff; 
            padding: 18px 40px; 
            border-radius: 100px; 
            font-weight: 800; 
            border: none; 
            cursor: pointer; 
            transition: 0.3s; 
            width: 100%; 
            font-family: 'Manrope', sans-serif;
            font-size: 16px;
        }
        .btn-submit-vk:hover { background: #5249ff; transform: translateY(-2px); box-shadow: 0 10px 20px rgba(99, 91, 255, 0.2); }

        @media (max-width: 992px) { .profile-layout { grid-template-columns: 1fr; } .profile-sidebar { position: static; } }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="container">
        <div class="profile-layout">
            <aside class="profile-sidebar">
                <div class="profile-menu">
                    <a href="/organizer/dashboard" class="menu-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                        Дашборд
                    </a>
                    <a href="/organizer/events" class="menu-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        Мои мероприятия
                    </a>
                    <a href="/organizer/events/create" class="menu-btn active">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        Создать мероприятие
                    </a>
                    <a href="/user/profile?tab=notifications" class="menu-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        Уведомления
                    </a>
                </div>
            </aside>

            <main class="profile-content">
                <form action="/organizer/events/create" method="POST" enctype="multipart/form-data" id="event-form">
                    <input type="hidden" name="is_web_form" value="true">
                    <div class="vk-form-group">
                        <label class="vk-label">Название мероприятия</label>
                        <input type="text" name="title" class="vk-input" required placeholder="Например: Фестиваль уличной еды">
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div class="vk-form-group">
                            <label class="vk-label">Категория</label>
                            <select name="category_id" class="vk-input" required>
                                <option value="1">Сезонные</option>
                                <option value="2">Тематические</option>
                                <option value="3">Мастер-классы</option>
                                <option value="4">Выездные</option>
                            </select>
                        </div>
                        <div class="vk-form-group">
                            <label class="vk-label">Количество участников</label>
                            <input type="number" name="max_participants" class="vk-input" required min="1" value="50">
                        </div>
                    </div>

                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                        <div class="vk-form-group">
                            <label class="vk-label">Дата и время проведения</label>
                            <input type="datetime-local" name="date" class="vk-input" required>
                        </div>
                        <div class="vk-form-group">
                            <label class="vk-label">Адрес (Улица, дом)</label>
                            <input type="text" name="location" id="location-input" class="vk-input" required placeholder="Оренбург, ул. Чкалова, 1">
                        </div>
                    </div>

                    <div class="vk-form-group">
                        <label class="vk-label">Описание мероприятия</label>
                        <textarea name="description" class="vk-input" rows="5" required placeholder="Подробно опишите ваше мероприятие..."></textarea>
                    </div>

                    <div class="vk-form-group">
                        <label class="vk-label">Изображение мероприятия</label>
                        <div class="upload-box" onclick="document.getElementById('media-input-single').click()" style="height: 240px; border: 2px dashed #e2e8f0; border-radius: 24px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.3s; background: #f8fafc; position: relative; overflow: hidden;">
                            <div id="upload-content" style="display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center;">
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"></path><circle cx="12" cy="13" r="4"></circle></svg>
                                <p style="font-size: 14px; color: #94a3b8; margin-top: 16px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;">Нажмите, чтобы выбрать фото</p>
                            </div>
                            <input type="file" id="media-input-single" name="media" accept="image/*" style="display: none;" onchange="previewSingleImg(this)">
                            <img id="single-preview" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; display: none;">
                        </div>
                    </div>

                    <button type="submit" class="btn-submit-vk">Отправить на модерацию</button>
                </form>
            </main>
        </div>
    </div>

    <script>
        function previewSingleImg(input) {
            const preview = document.getElementById('single-preview');
            const content = document.getElementById('upload-content');
            const box = input.parentElement;
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    content.style.display = 'none';
                    box.style.borderStyle = 'solid';
                    box.style.borderColor = '#635bff';
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>

    <%- include('../partials/footer') %>
</body>
</html>
