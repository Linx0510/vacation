<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Каталог мероприятий - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        body {
            background: #fff;
        }
        .catalog-container {
            background: #fff;
        }
        .catalog-hero {
            padding: 60px 0 40px;
            text-align: center;
            background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
            border-radius: 0 0 40px 40px;
            position: relative;
            overflow: hidden;
        }
        .catalog-hero h1 { 
            font-size: 3rem; 
            font-weight: 800; 
            color: #1e293b; 
            margin-bottom: 30px; 
            letter-spacing: -2px; 
        }
        .catalog-hero h1 span { 
            color: var(--primary-purple); 
        }

        .search-bar-wrapper {
            max-width: 700px;
            margin: 0 auto;
            position: relative;
            z-index: 10;
        }
        .search-form {
            display: flex;
            gap: 12px;
            background: white;
            padding: 8px;
            border-radius: 60px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.08);
            border: 1px solid #f1f5f9;
        }
        .search-input-group {
            flex: 1;
            display: flex;
            align-items: center;
            padding-left: 20px;
            background: #f8fafc;
            border-radius: 50px;
            border: 1px solid #e2e8f0;
            transition: all 0.3s ease;
        }
        .search-input-group:focus-within {
            border-color: var(--primary-purple);
            background: #fff;
        }
        .search-icon { 
            color: #94a3b8; 
            margin-right: 12px; 
            width: 20px;
            height: 20px;
        }
        .search-input-group input {
            width: 100%;
            border: none;
            padding: 14px 0;
            font-family: inherit;
            font-size: 15px;
            outline: none;
            background: transparent;
        }
        .btn-search {
            padding: 0 35px;
            border-radius: 50px;
            background: var(--primary-purple);
            color: white;
            border: none;
            font-weight: 700;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .btn-search:hover { 
            background: #4f46e5; 
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(99, 91, 255, 0.3);
        }

        .catalog-filters {
            padding: 30px 0 20px;
            background: #fff;
        }
        .category-filter-chips {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px;
            margin-bottom: 30px;
        }
        .filter-chip-link {
            display: inline-block;
            padding: 10px 24px;
            background: #f8fafc;
            color: #64748b;
            border-radius: 40px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 1px solid #e2e8f0;
        }
        .filter-chip-link.active {
            background: var(--primary-purple);
            color: #fff;
            border-color: var(--primary-purple);
            box-shadow: 0 4px 12px rgba(99, 91, 255, 0.25);
        }
        .filter-chip-link:hover {
            background: var(--light-purple);
            color: var(--primary-purple);
            transform: translateY(-2px);
        }

        .other-filters-row {
            display: flex;
            justify-content: center;
            margin-top: 10px;
        }
        .filter-group-date {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #fff;
            padding: 12px 24px;
            border-radius: 60px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        }
        .date-inputs {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .date-input-field {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #f8fafc;
            padding: 8px 16px;
            border-radius: 40px;
            border: 1px solid #e2e8f0;
        }
        .date-hint {
            font-size: 13px;
            font-weight: 600;
            color: #94a3b8;
        }
        .date-input-field input {
            border: none;
            background: transparent;
            padding: 6px 0;
            font-family: 'Manrope', sans-serif;
            font-size: 14px;
            outline: none;
            color: #1e293b;
        }
        .date-separator {
            color: #cbd5e1;
        }
        .btn-apply-date {
            background: var(--primary-purple);
            color: white;
            border: none;
            padding: 10px 24px;
            border-radius: 40px;
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .btn-apply-date:hover {
            background: #4f46e5;
            transform: translateY(-2px);
        }
        .btn-reset-date {
            background: #f1f5f9;
            color: #64748b;
            border: none;
            padding: 8px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
        .btn-reset-date:hover {
            background: #fee2e2;
            color: #ef4444;
        }

        .btn-reset-all {
    background: #f1f5f9;
    color: #64748b;
    border: none;
    padding: 8px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
}
.btn-reset-all:hover {
    background: #fee2e2;
    color: #ef4444;
}

        .events-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 30px;
            padding: 40px 0;
            background: #fff;
        }
        .event-card {
            background: #fff;
            border-radius: 24px;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            border: 1px solid #f1f5f9;
        }
        .event-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 35px rgba(0,0,0,0.08);
            border-color: rgba(99, 91, 255, 0.15);
        }
        .event-image {
            height: 200px;
            overflow: hidden;
            position: relative;
        }
        .event-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }
        .event-card:hover .event-image img {
            transform: scale(1.05);
        }
        .category-badge {
            position: absolute;
            top: 15px;
            left: 15px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 800;
            color: #fff;
            border: none;
            backdrop-filter: none;
            z-index: 2;
        }
        .event-info {
            padding: 20px;
        }
        .event-meta-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }
        .event-date-tag {
            font-size: 12px;
            color: #64748b;
            display: flex;
            align-items: center;
            gap: 4px;
            font-weight: 600;
        }
        .event-info h3 {
            font-size: 18px;
            font-weight: 800;
            margin: 0 0 10px 0;
            color: #1e293b;
            line-height: 1.4;
        }
        .event-desc {
            font-size: 14px;
            color: #64748b;
            line-height: 1.5;
            margin-bottom: 15px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .event-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #f1f5f9;
        }
        .event-location {
            font-size: 12px;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .btn-vk-primary {
            background: var(--primary-purple);
            color: #fff;
            padding: 8px 20px;
            border-radius: 30px;
            text-decoration: none;
            font-weight: 700;
            font-size: 13px;
            transition: all 0.3s ease;
            display: inline-block;
        }
        .btn-vk-primary:hover {
            background: #4f46e5;
            transform: translateY(-2px);
        }
        .hidden-event {
            display: none;
        }
        .load-more-wrapper {
            text-align: center;
            margin: 40px 0 60px;
            background: #fff;
        }
        .btn-load-more {
            padding: 15px 40px;
            border-radius: 50px;
            border: 2px solid var(--primary-purple);
            background: transparent;
            color: var(--primary-purple);
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        .btn-load-more:hover {
            background: var(--primary-purple);
            color: #fff;
            transform: translateY(-2px);
        }
        .no-results-container {
            text-align: center;
            padding: 80px 0;
            grid-column: 1 / -1;
            background: #fff;
        }
        .no-results-icon-anim svg {
            width: 80px;
            height: 80px;
            margin-bottom: 20px;
            opacity: 0.5;
        }
        .no-results-title {
            font-size: 24px;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 10px;
        }
        .no-results-text {
            color: #64748b;
            margin-bottom: 25px;
        }
        .btn-reset-filters-premium {
            background: var(--primary-purple);
            color: #fff;
            padding: 12px 30px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 700;
            display: inline-block;
        }
        .events-grid-loading {
            opacity: 0.6;
            transition: opacity 0.2s ease;
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <main class="catalog-container container">
        <section class="catalog-hero">
            <h1>Найдите своё <span>идеальное мероприятие</span></h1>
            
            <div class="search-bar-wrapper">
                <form action="/events" method="GET" class="search-form" id="searchForm" data-ajax="true">
                    <div class="search-input-group">
                        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                        <input type="text" name="search" id="searchInput" placeholder="Поиск по названию или описанию..." value="<%= filters.search || '' %>">
                    </div>
                    <% if (filters.category) { %><input type="hidden" name="category" value="<%= filters.category %>"><% } %>
                    <% if (filters.date_from) { %><input type="hidden" name="date_from" value="<%= filters.date_from %>"><% } %>
                    <% if (filters.date_to) { %><input type="hidden" name="date_to" value="<%= filters.date_to %>"><% } %>
                    <button type="submit" class="btn-search">Найти</button>
                </form>
            </div>
        </section>

        <section class="catalog-filters">
            <div class="category-filter-chips" id="categoryChips">
                <% const cats = [{id:'all', name:'Все'}, {id:'seasonal', name:'Сезонные'}, {id:'thematic', name:'Тематические'}, {id:'workshop', name:'Мастер-классы'}, {id:'outdoor', name:'Выездные'}]; %>
                <% cats.forEach(cat => { %>
                    <label class="filter-chip-link <%= (filters.category === cat.id || (!filters.category && cat.id === 'all')) ? 'active' : '' %>" data-category="<%= cat.id %>">
                        <%= cat.name %>
                    </label>
                <% }) %>
            </div>

           <div class="other-filters-row">
    <div class="filter-group-date" id="dateFilterGroup">
        <div class="date-inputs">
            <div class="date-input-field">
                <span class="date-hint">с</span>
                <input type="date" name="date_from" id="dateFrom" value="<%= filters.date_from || '' %>" min="<%= new Date().toISOString().split('T')[0] %>">
            </div>
            <span class="date-separator">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            </span>
            <div class="date-input-field">
                <span class="date-hint">по</span>
                <input type="date" name="date_to" id="dateTo" value="<%= filters.date_to || '' %>" min="<%= new Date().toISOString().split('T')[0] %>">
            </div>
            <button type="button" class="btn-apply-date" id="applyDateBtn">
                <span>Применить</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </button>
            <button type="button" class="btn-reset-all" id="resetAllBtn" title="Сбросить все фильтры">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                    <path d="M3 3v5h5"></path>
                </svg>
            </button>
            <% if (filters.date_from || filters.date_to) { %>
                <a href="#" class="btn-reset-date" id="resetDateBtn" title="Сбросить даты">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
                </a>
            <% } %>
        </div>
    </div>
</div>
        </section>

        <section class="events-grid" id="eventsGrid">
            <% 
                // Находим тестовое мероприятие и выносим его в начало
                const testEventIndex = events.findIndex(e => e.title && e.title.includes('проверки оплаты'));
                let sortedEvents = [...events];
                if (testEventIndex !== -1) {
                    const testEvent = sortedEvents.splice(testEventIndex, 1)[0];
                    sortedEvents.unshift(testEvent);
                }
            %>
            <% if (sortedEvents && sortedEvents.length > 0) { %>
                <% sortedEvents.forEach((event, index) => { %>
                    <% 
                        const catMap = { '1': 'Сезонные', '2': 'Тематические', '3': 'Мастер-классы', '4': 'Выездные' };
                        const catName = catMap[event.category_id] || 'Мероприятие';
                        const isTestEvent = event.title && event.title.includes('проверки оплаты');
                    %>
                    <div class="event-card <%= index >= 6 ? 'hidden-event' : '' %>" 
                         data-index="<%= index %>"
                         style="<%= isTestEvent ? 'border: 2px dashed #635bff; position: relative;' : '' %>">
                        
                        <% if (isTestEvent) { %>
                            <div style="position: absolute; top: 15px; right: 15px; background: #635bff; color: #fff; padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 800; z-index: 10; box-shadow: 0 4px 12px rgba(99, 91, 255, 0.4);">
                                500 руб.
                            </div>
                        <% } %>

                        <div class="event-image">
                            <% if (isTestEvent) { %>
                                <img src="/images/static/friends-party-with-delicious-pizza.jpg" alt="<%= event.title %>">
                            <% } else if (event.media_url) { %>
                                <img src="<%= event.media_url %>" alt="<%= event.title %>" onerror="this.src='/images/static/event-1.jpg'">
                            <% } else { %>
                                <img src="/images/static/event-1.jpg" alt="Default">
                            <% } %>
                            <div class="category-badge">
                                <span class="badge-text"><%= catName %></span>
                            </div>
                        </div>
                        <div class="event-info">
                            <div class="event-meta-top" style="display: flex; justify-content: space-between; align-items: center;">
                                <span class="event-date-tag">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                    <%= isTestEvent ? '30 июня' : new Date(event.date).toLocaleDateString('ru-RU', { day: 'numeric', month: 'long' }) %>
                                </span>
                                <% if (!isTestEvent && event.price && event.price > 0) { %>
                                    <span style="background: #635bff; color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 800; margin-left: auto; box-shadow: 0 4px 10px rgba(99, 91, 255, 0.2);">
                                        <%= event.price %> ₽
                                    </span>
                                <% } %>
                            </div>
                            <h3><%= event.title %></h3>
                            <div style="margin-bottom: 10px; font-size: 13px; color: #64748b; font-weight: 600; display: flex; align-items: center; gap: 5px;">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                                Идет: <span class="participants-count" data-id="<%= event.id %>"><%= event.participants_count || 0 %></span> / <%= event.max_participants || 50 %>
                            </div>
                            <p class="event-desc"><%= event.description.substring(0, 100) %>...</p>
                            <div class="event-footer">
                                <span class="event-location">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                    <%= isTestEvent ? 'Оренбург, Советская 45' : (event.location || 'Адрес не указан') %>
                                </span>
                                <a href="/events/<%= event.id %>" class="btn-vk-primary">Подробнее</a>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="no-results-container">
                    <div class="no-results-icon-anim">
                        <svg viewBox="0 0 24 24" fill="none" stroke="#635bff" stroke-width="1.5">
                            <circle cx="11" cy="11" r="8"></circle>
                            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                        </svg>
                    </div>
                    <h2 class="no-results-title">Ничего не нашлось</h2>
                    <p class="no-results-text">К сожалению, по вашему запросу мероприятий не найдено.</p>
                    <a href="/events" class="btn-reset-filters-premium">Сбросить всё</a>
                </div>
            <% } %>
        </section>

        <div class="load-more-wrapper" id="loadMoreWrapper" style="<%= (events && events.length > 6) ? '' : 'display: none;' %>">
            <button id="loadMoreBtn" class="btn-load-more">Показать еще</button>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script src="/js/main.js"></script>
    <script src="/js/filters.js"></script>
</body>
</html>