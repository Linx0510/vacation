<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= event.title %> - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        :root {
            --radius-xl: 32px;
            --radius-lg: 24px;
            --radius-md: 16px;
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --primary-purple: #635bff;
            --dark-purple: #4f46e5;
            --light-purple: #e0dfff;
        }

        .single-event-body {
            background-color: #fff;
        }

        .event-hero-section {
            background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
            padding: 30px 0 40px;
            margin: 0;
        }

        .breadcrumb {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 24px;
            font-size: 14px;
        }

        .breadcrumb a {
            color: #64748b;
            text-decoration: none;
            font-weight: 600;
            transition: var(--transition);
        }

        .breadcrumb a:hover {
            color: var(--primary-purple);
        }

        .event-category-tag {
            background: var(--light-purple);
            color: var(--primary-purple);
            padding: 6px 14px;
            border-radius: 100px;
            font-weight: 800;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            display: inline-block;
            margin-bottom: 16px;
        }

        .event-title {
            font-size: 3.5rem;
            font-weight: 800;
            color: #1a1a1a;
            line-height: 1.1;
            margin: 0;
            letter-spacing: -0.02em;
        }

        .event-main-grid {
            display: grid;
            grid-template-columns: 1fr 380px;
            gap: 48px;
            margin-top: 40px;
        }

        .main-image-wrapper {
            height: 540px;
            border-radius: var(--radius-xl);
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            margin-bottom: 40px;
        }

        .main-image-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .content-card {
            background: #fff;
            border-radius: var(--radius-xl);
            padding: 40px;
            border: 1px solid #f1f5f9;
            margin-bottom: 32px;
        }

        .section-title {
            font-size: 24px;
            font-weight: 800;
            color: #1a1a1a;
            margin-bottom: 20px;
            margin-top: 0px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .description-text {
            font-size: 16px;
            line-height: 1.8;
            color: #475569;
        }

        .sidebar-sticky {
            position: sticky;
            top: 100px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .action-card {
            background: #fff;
            color: #1a1a1a;
            padding: 24px;
            border-radius: var(--radius-lg);
            box-shadow: 0 20px 40px rgba(0,0,0,0.06);
            border: 1px solid #f1f5f9;
        }

        .price-row {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .price-dot {
            width: 10px;
            height: 10px;
            background: #22c55e;
            border-radius: 50%;
            box-shadow: 0 0 12px rgba(34, 197, 94, 0.4);
        }

        .btn-main {
            width: 100%;
            padding: 18px 32px;
            border-radius: 100px;
            font-weight: 700;
            font-size: 16px;
            cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
            font-family: 'Manrope', sans-serif;
        }

        .btn-primary {
            background: var(--primary-purple);
            color: #fff;
            box-shadow: 0 4px 15px rgba(99, 91, 255, 0.2);
        }

        .btn-primary:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 12px 25px rgba(99, 91, 255, 0.4);
            background: var(--dark-purple);
        }

        .btn-outline {
            background: #f8fafc;
            color: var(--primary-purple);
            border: 1px solid #f1f5f9;
            margin-top: 12px;
        }

        .btn-outline:hover {
            background: #fff;
            border-color: var(--primary-purple);
            transform: translateY(-3px);
        }

        .btn-primary.active {
            background: #94a3b8;
            color: #fff;
        }

        .btn-primary.active:hover {
            background: #64748b;
        }

        .btn-outline.active {
            background: var(--light-purple);
            color: var(--primary-purple);
            border-color: var(--light-purple);
        }

        .organizer-card {
            background: #f8fafc;
            padding: 20px;
            border-radius: var(--radius-lg);
            border: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .org-avatar {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            object-fit: cover;
        }

        .org-link {
            color: var(--primary-purple);
            text-decoration: none;
            font-size: 14px;
            font-weight: 700;
        }

        .map-container {
            height: 400px;
            border-radius: var(--radius-lg);
            overflow: hidden;
            margin-top: 24px;
            border: 1px solid #f1f5f9;
        }

        .review-item {
            background: #f8fafc;
            padding: 24px;
            border-radius: var(--radius-lg);
            margin-bottom: 16px;
            border: 1px solid #f1f5f9;
        }

        .review-user-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 12px;
            align-items: center;
        }

        .review-user-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
        }

        .review-user-placeholder {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--light-purple);
            color: var(--primary-purple);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 18px;
        }

        .btn-show-more {
            width: 100%;
            padding: 16px;
            background: #f1f5f9;
            color: #475569;
            border: none;
            border-radius: var(--radius-md);
            font-weight: 700;
            cursor: pointer;
        }

        .stat-card {
            padding: 16px;
            background: #f8fafc;
            border-radius: 16px;
            text-align: center;
        }
        
        .stat-label {
            font-size: 11px;
            color: #94a3b8;
            margin-bottom: 8px;
            font-weight: 800;
            text-transform: uppercase;
        }
        
        .stat-value {
            font-weight: 800;
            font-size: 20px;
            color: #1a1a1a;
        }

        .action-card-fixed {
            min-height: 360px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .stats-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 20px;
        }

        .buttons-container {
            margin-top: 8px;
        }

        /* Оригинальные скругления кнопок */
        .btn-join, .btn-favorite {
            border-radius: 100px !important;
        }

        @media (max-width: 1024px) {
            .event-main-grid {
                grid-template-columns: 1fr;
            }
            .event-title {
                font-size: 2.5rem;
            }
        }
    </style>
</head>
<body class="single-event-body">
    <%- include('../partials/header') %>

    <main>
        <section class="event-hero-section">
            <div class="container">
                <nav class="breadcrumb">
                    <a href="/events">Мероприятия</a>
                    <span style="color: #cbd5e1;">/</span>
                    <span style="color: var(--primary-purple); font-weight: 700;"><%= event.title %></span>
                </nav>

                <div class="event-header-content">
                    <span class="event-category-tag">
                        <% 
                            var catMap = { '1': 'Сезонные', '2': 'Тематические', '3': 'Мастер-классы', '4': 'Выездные' };
                            var catName = catMap[event.category_id] || 'Мероприятие';
                        %>
                        <%= catName %>
                    </span>
                    <h1 class="event-title">
                        <% if (event.title && event.title.includes('Тестовое мероприятие для проверки оплаты')) { %>
                            Тестовое мероприятие<br>для проверки оплаты
                        <% } else { %>
                            <%= event.title %>
                        <% } %>
                    </h1>
                </div>
            </div>
        </section>

        <div class="container">
            <div class="event-main-grid">
                <div class="event-left-content">
                    <div class="main-image-wrapper">
                        <% if (event.title && event.title.includes('проверки оплаты')) { %>
                            <img src="/images/static/friends-party-with-delicious-pizza.jpg" id="main-img" alt="<%= event.title %>">
                        <% } else { %>
                            <img src="<%= event.media_url || '/images/static/event-1.jpg' %>" id="main-img" alt="<%= event.title %>">
                        <% } %>
                    </div>

                    <div class="content-card">
                        <h2 class="section-title">О мероприятии</h2>
                        <div class="description-text">
                            <%= event.description %>
                        </div>
                    </div>

                        <div class="content-card">
                            <h2 class="section-title">Место проведения</h2>
                            <div style="display: flex; align-items: center; gap: 12px; color: #1a1a1a; font-weight: 700; font-size: 18px;">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--primary-purple)" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                                <% if (event.title && event.title.includes('проверки оплаты')) { %>
                                    Оренбург, Советская 45
                                <% } else { %>
                                    <%= event.location %>
                                <% } %>
                            </div>
                            <div class="map-container">
                                <iframe width="100%" height="100%" frameborder="0" style="border:0;" src="https://yandex.ru/map-widget/v1/?text=<%= encodeURIComponent(event.title && event.title.includes('проверки оплаты') ? 'Оренбург, Советская 45' : event.location) %>&z=16" allowfullscreen></iframe>
                            </div>
                        </div>

                    <div class="content-card" style="background: linear-gradient(135deg, var(--primary-purple) 0%, var(--dark-purple) 100%); color: #fff; border: none; position: relative; overflow: hidden;">
                        <div style="position: relative; z-index: 2;">
                            <h2 class="section-title" style="color: #fff;">Предложите свою идею</h2>
                            <p style="font-size: 16px; opacity: 0.9; margin-bottom: 24px;">Организаторы возьмут в работу самые популярные предложения!</p>
<a href="/user/profile?tab=proposals" style="background: #fff; color: var(--primary-purple); padding: 14px 32px; border-radius: 100px; text-decoration: none; font-weight: 800; display: inline-block;">Оставить идею</a>                        </div>
                        <div style="position: absolute; right: -20px; bottom: -20px; opacity: 0.1;">
                            <svg width="200" height="200" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                        </div>
                    </div>

                    <div class="content-card">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32px;">
                            <h2 class="section-title" style="margin: 0;">Отзывы</h2>
                            <% if (user) { %>
<a href="/user/profile?tab=reviews" style="background: var(--light-purple); padding: 10px 24px; border-radius: 100px; text-decoration: none; font-weight: 700; color: var(--primary-purple);">Написать отзыв</a>                            <% } %>
                        </div>

                        <% if (reviews && reviews.length > 0) { %>
                            <div id="reviews-container">
                                <% reviews.forEach(function(review, index) { %>
                                    <div class="review-item" style="<%= index >= 3 ? 'display: none;' : '' %>">
                                        <div class="review-user-info">
                                            <div style="display: flex; align-items: center; gap: 12px;">
                                                <% if (review.user_avatar) { %>
                                                    <img src="<%= review.user_avatar.startsWith('/') ? review.user_avatar : '/' + review.user_avatar %>" class="review-user-avatar" alt="<%= review.first_name %>">
                                                <% } else { %>
                                                    <div class="review-user-placeholder">
                                                        <%= (review.first_name || 'А').charAt(0).toUpperCase() %>
                                                    </div>
                                                <% } %>
                                                <div>
                                                    <div style="font-weight: 700; color: #1a1a1a;"><%= review.first_name %> <%= review.last_name %></div>
                                                    <div style="font-size: 12px; color: #94a3b8;"><%= new Date(review.created_at).toLocaleDateString('ru-RU') %></div>
                                                </div>
                                            </div>
                                            <div style="display: flex; gap: 2px;">
                                                <% for(var i=0; i<5; i++) { %>
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="<%= i < review.rating ? '#f59e0b' : '#e2e8f0' %>"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                                                <% } %>
                                            </div>
                                        </div>
                                        <p style="margin: 0; color: #475569; line-height: 1.6;"><%= review.comment %></p>
                                    </div>
                                <% }); %>
                            </div>
                            <% if (reviews.length > 3) { %>
                                <button id="show-more-reviews" class="btn-show-more">Показать все отзывы</button>
                            <% } %>
                        <% } else { %>
                            <div style="text-align: center; padding: 40px; background: #f8fafc; border-radius: var(--radius-lg); color: #94a3b8; font-weight: 600;">Пока нет отзывов. Будьте первым!</div>
                        <% } %>
                    </div>
                </div>

                <aside class="sidebar-wrapper">
                    <div class="sidebar-sticky">
                        <div class="action-card action-card-fixed">
                            <div>
                                <div class="price-row">
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <div class="price-dot" style="background: <%= event.price > 0 ? '#d97706' : '#22c55e' %>; box-shadow: 0 0 12px <%= event.price > 0 ? 'rgba(217, 119, 6, 0.4)' : 'rgba(34, 197, 94, 0.4)' %>;"></div>
                                        <div>
                                            <% if (event.id == 1 || event.id == '1' || (event.title && event.title.includes('проверки оплаты'))) { %>
                                                Вход<br>500 руб.
                                            <% } else if (event.price > 0) { %>
                                                Вход<br><%= event.price %> руб.
                                            <% } else { %>
                                                Вход<br>свободный
                                            <% } %>
                                        </div>
                                    </div>
                                    <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 8px;">
                                        <button onclick="history.back()" style="background: none; border: none; color: #94a3b8; cursor: pointer; font-weight: 700; display: flex; align-items: center; gap: 6px;">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                                            Назад
                                        </button>
                                        <button id="printTicketBtn" onclick="printEvent()" style="background: none; border: none; color: #635bff; cursor: pointer; font-weight: 700; display: <%= (user && isGoing) ? 'flex' : 'none' %>; align-items: center; gap: 6px; font-size: 14px;">
                                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M6 18L18 18"></path>
                                                <path d="M6 14L18 14"></path>
                                                <rect x="8" y="2" width="8" height="4" rx="1"></rect>
                                                <rect x="4" y="6" width="16" height="12" rx="1"></rect>
                                            </svg>
                                            Печать
                                        </button>
                                    </div>
                                </div>

                                <div class="stats-container">
                                    <div class="stat-card">
                                        <div class="stat-label">Участники</div>
                                        <div class="stat-value">
                                            <span class="participants-count" data-id="<%= event.id %>"><%= event.participants_count || 0 %></span> / <%= event.max_participants || 50 %>
                                        </div>
                                    </div>
                                    <div class="stat-card">
                                        <div class="stat-label">Дата</div>
                                        <div class="stat-value">
                                            <% if (event.title && event.title.includes('проверки оплаты')) { %>
                                                30 июня
                                            <% } else { %>
                                                <%= new Date(event.date).toLocaleDateString('ru-RU', { day: 'numeric', month: 'short' }) %>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="buttons-container">
                                <% if (user) { %>
                                    <button class="btn-main btn-primary btn-join <%= isGoing ? 'active' : '' %>" data-id="<%= event.id %>" style="border-radius: 100px;">
                                        <%= isGoing ? 'Вы идете' : 'Я иду' %>
                                    </button>
                                    <button class="btn-main btn-outline btn-favorite <%= isFavorite ? 'active' : '' %>" data-id="<%= event.id %>" style="border-radius: 100px;">
                                        <svg width="20" height="20" viewBox="0 0 24 24" fill="<%= isFavorite ? 'currentColor' : 'none' %>" stroke="currentColor" stroke-width="2.5">
                                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                                        </svg>
                                        <%= isFavorite ? 'В избранном' : 'В избранное' %>
                                    </button>
                                <% } else { %>
                                    <a href="/auth/login" class="btn-main btn-primary" style="text-decoration: none; display: block; text-align: center; border-radius: 100px;">Войти и записаться</a>
                                <% } %>
                            </div>
                        </div>

                        <div class="organizer-card">
                            <% if (event.avatar) { %>
                                <img src="<%= event.avatar.startsWith('/') ? event.avatar : '/' + event.avatar %>" class="org-avatar">
                            <% } else { %>
                                <div style="width: 48px; height: 48px; border-radius: 12px; background: var(--light-purple); color: var(--primary-purple); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 18px;">
                                    <%= (event.first_name || 'О').charAt(0) %>
                                </div>
                            <% } %>
                            <div>
                                <div style="font-size: 10px; color: #94a3b8; font-weight: 800; text-transform: uppercase;">Организатор</div>
                                <a href="/organizer/<%= event.organizer_id %>" class="org-link"><%= event.first_name %> <%= event.last_name %></a>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>

    <script src="/js/main.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const showMoreBtn = document.getElementById('show-more-reviews');
            if (showMoreBtn) {
                showMoreBtn.addEventListener('click', function() {
                    const reviews = document.querySelectorAll('.review-item');
                    reviews.forEach(r => r.style.display = 'block');
                    this.style.display = 'none';
                });
            }
        });

        function printEvent() {
            const eventTitle = document.querySelector('.event-title').innerText;
            const eventDate = document.querySelector('.stat-card:last-child .stat-value').innerText;
            const eventLocationElem = document.querySelector('.content-card .org-link');
            const eventLocation = eventLocationElem ? eventLocationElem.closest('div').previousElementSibling.innerText : 'Адрес не указан';
            const eventUrl = window.location.href;
            const userName = '<%= user ? user.first_name + " " + user.last_name : "Гость" %>';
            const printWindow = window.open('', '_blank');
            
            const html = `<!DOCTYPE html>
            <html>
            <head>
                <title>Печать мероприятия - Вакация</title>
                <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;700;800&display=swap" rel="stylesheet">
                <style>
                    * { margin: 0; padding: 0; box-sizing: border-box; }
                    body { font-family: 'Manrope', sans-serif; padding: 40px; color: #1a1a1a; line-height: 1.6; background: #fff; }
                    .ticket { border: 2px solid #635bff; border-radius: 24px; padding: 40px; max-width: 700px; margin: 0 auto; position: relative; }
                    .header { text-align: center; border-bottom: 1px dashed #e2e8f0; padding-bottom: 20px; margin-bottom: 30px; }
                    .brand { color: #635bff; font-weight: 800; font-size: 24px; letter-spacing: 2px; }
                    .title { font-size: 32px; font-weight: 800; margin: 20px 0; line-height: 1.2; }
                    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px; }
                    .info-item { background: #f8fafc; padding: 15px; border-radius: 12px; }
                    .label { font-size: 11px; color: #94a3b8; text-transform: uppercase; font-weight: 800; margin-bottom: 5px; }
                    .value { font-weight: 700; font-size: 16px; }
                    .description { border-top: 1px dashed #e2e8f0; padding-top: 20px; margin-top: 20px; font-size: 14px; color: #475569; }
                    .footer { margin-top: 40px; display: flex; justify-content: space-between; align-items: flex-end; font-size: 12px; color: #94a3b8; }
                    .no-print { margin-bottom: 20px; text-align: center; }
                    .btn-back-print { 
                        display: inline-flex; 
                        align-items: center; 
                        gap: 8px; 
                        padding: 10px 20px; 
                        background: #635bff; 
                        color: #fff; 
                        text-decoration: none; 
                        border-radius: 12px; 
                        font-weight: 700; 
                        font-size: 14px; 
                        border: none;
                        cursor: pointer;
                    }
                    @media print {
                        .no-print { display: none; }
                    }
                </style>
            </head>
            <body>
                <div class="no-print">
                    <button onclick="window.close()" class="btn-back-print">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="19" y1="12" x2="5" y2="12"></line>
                            <polyline points="12 19 5 12 12 5"></polyline>
                        </svg>
                        Назад к мероприятию
                    </button>
                </div>
                <div class="ticket">
                    <div class="header">
                        <div class="brand">ВАКАЦИЯ - МЕРОПРИЯТИЕ</div>
                    </div>
                    <div class="title">${eventTitle}</div>
                    <div class="info-grid">
                        <div class="info-item">
                            <div class="label">Дата</div>
                            <div class="value">${eventDate}</div>
                        </div>
                        <div class="info-item">
                            <div class="label">Место</div>
                            <div class="value">${eventLocation}</div>
                        </div>
                        <div class="info-item">
                            <div class="label">Посетитель</div>
                            <div class="value">${userName}</div>
                        </div>
                        <div class="info-item">
                            <div class="label">Стоимость</div>
                            <div class="value">Вход свободный</div>
                        </div>
                    </div>
                    <div class="description">
                        <strong>Описание:</strong><br>
                        ${document.querySelector('.description-text') ? document.querySelector('.description-text').innerText : ''}
                    </div>
                    <div class="footer">
                        <div>
                            <strong>Дата печати:</strong> ${new Date().toLocaleDateString('ru-RU')}<br>
                            <strong>ID мероприятия:</strong> #<%= event.id %>
                        </div>
                        <div id="qrcode"></div>
                    </div>
                </div>
                <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"><\/script>
                <script>
                    new QRCode(document.getElementById("qrcode"), {
                        text: "${eventUrl}",
                        width: 100,
                        height: 100,
                        colorDark: "#635bff",
                        colorLight: "#ffffff",
                        correctLevel: QRCode.CorrectLevel.H
                    });
                    setTimeout(function() { 
                        window.print();
                    }, 500);
                <\/script>
            </body>
