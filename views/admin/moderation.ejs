<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Модерация - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .admin-layout { display: grid; grid-template-columns: 280px 1fr; gap: 30px; padding: 40px 0; align-items: start; }
        .admin-sidebar { background: #fff; border-radius: 24px; padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.04); position: sticky; top: 100px; }
        .admin-menu { display: flex; flex-direction: column; gap: 5px; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 12px 20px; border-radius: 12px; text-decoration: none; color: #64748b; font-family: 'Manrope', sans-serif; font-weight: 600; font-size: 15px; transition: 0.3s; }
        .menu-item svg { width: 18px; height: 18px; stroke-width: 2px; }
        .menu-item:hover { color: #635bff; background: #f8fafc; }
        .menu-item.active { background: #635bff; color: #fff; box-shadow: 0 4px 12px rgba(99, 91, 255, 0.25); }
        .admin-content { background: #fff; border-radius: 24px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.04); min-height: 500px; box-sizing: border-box; }
        .section-title { font-family: 'Manrope', sans-serif; font-size: 28px; font-weight: 800; margin-bottom: 25px; color: #1e293b; }
        
        /* Таблицы */
        .admin-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; margin-top: -12px; }
        .admin-table th { text-align: left; padding: 15px 20px; color: #94a3b8; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
        .admin-table tr { background: #f8fafc; transition: 0.3s; }
        .admin-table tr:hover { transform: scale(1.01); box-shadow: 0 5px 15px rgba(0,0,0,0.03); }
        .admin-table td { padding: 18px 20px; vertical-align: middle; }
        .admin-table td:first-child { border-radius: 16px 0 0 16px; }
        .admin-table td:last-child { border-radius: 0 16px 16px 0; }
        
        /* Статусы на русском */
        .status-badge { 
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 12px;
            font-weight: 700;
            white-space: nowrap;
        }
        .status-pending { background: #fff7ed; color: #c2410c; }
        .status-approved { background: #f0fdf4; color: #166534; }
        .status-rejected { background: #fef2f2; color: #991b1b; }
        .status-voting { background: #f0fdf4; color: #166534; }
        .status-moderation { background: #fef9e6; color: #b87307; }
        .status-in_progress { background: #eff6ff; color: #1d4ed8; }
        .status-completed { background: #f0fdf4; color: #166534; }
        .status-requires_changes { background: #fef9e6; color: #b87307; }
        
        /* Кнопки */
        .btn-action { 
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 8px 0;
            border-radius: 30px;
            font-size: 13px;
            font-weight: 700;
            text-decoration: none;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-family: 'Manrope', sans-serif;
            white-space: nowrap;
            width: 110px;
        }
        .btn-view { background: #f0f0ff; color: #635bff; }
        .btn-view:hover { background: #635bff; color: #fff; transform: translateY(-2px); }
        .btn-delete { background: #fee2e2; color: #dc2626; }
        .btn-delete:hover { background: #dc2626; color: #fff; transform: translateY(-2px); }
        
        /* Кнопки Одобрить и Отклонить - фиолетовые, ширина 180px, высота 56px */
        .btn-approve, .btn-reject { 
            width: 180px;
            height: 56px;
            background: #635bff;
            color: #fff;
            border: none;
            border-radius: 16px;
            font-size: 16px;
            font-weight: 700;
            font-family: 'Manrope', sans-serif;
            cursor: pointer;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .btn-approve:hover, .btn-reject:hover { 
            background: #4f46e5;
            transform: translateY(-2px);
        }
        
        .btn-back { background: #f1f5f9; color: #64748b; }
        .btn-back:hover { background: #e2e8f0; color: #1e293b; }
        
        .btn-group {
            display: flex;
            gap: 12px;
            align-items: center;
            justify-content: flex-start;
            flex-wrap: wrap;
        }
        
        /* Ряд кнопок в детальной странице */
        .decision-buttons {
            display: flex;
            flex-direction: row;
            gap: 15px;
            justify-content: center;
            align-items: center;
        }
        
        .tab-btn { 
            padding: 10px 24px; 
            border-radius: 40px; 
            font-size: 14px; 
            font-weight: 700; 
            border: none; 
            cursor: pointer; 
            transition: 0.3s; 
        }
        .tab-btn:hover { transform: translateY(-2px); }
        
        .empty-state { text-align: center; padding: 60px 20px; background: #f8fafc; border-radius: 20px; color: #94a3b8; }
        hr { margin: 40px 0; border: none; border-top: 1px solid #f1f5f9; }
        
        /* Детальная страница */
        .detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 30px; }
        .detail-card { background: #f8fafc; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; }
        .detail-card h3 { font-size: 14px; color: #635bff; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 20px; font-weight: 800; }
        .media-card { background: #f8fafc; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; margin-bottom: 30px; }
        .media-card img { width: 100%; border-radius: 16px; cursor: pointer; max-height: 250px; object-fit: contain; background: #fff; }
        .decision-card { background: #f8fafc; padding: 35px; border-radius: 30px; border: 1px solid #f1f5f9; }
        .comment-area { width: 100%; padding: 15px; border-radius: 12px; border: 1px solid #e2e8f0; background: #fff; font-family: inherit; margin-bottom: 20px; resize: vertical; }
        .template-select { width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; margin-bottom: 15px; font-family: inherit; background: #fff; }
        
        @media (max-width: 992px) { 
            .admin-layout { grid-template-columns: 1fr; } 
            .admin-sidebar { position: static; } 
            .detail-grid { grid-template-columns: 1fr; }
            .btn-group { flex-direction: column; align-items: stretch; }
            .btn-action { width: 100%; }
            .btn-approve, .btn-reject { width: 100%; }
            .decision-buttons { flex-direction: column; }
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>
    <div class="container">
        <div class="admin-layout">
            <aside class="admin-sidebar">
                <div class="admin-menu">
                    <a href="/admin/dashboard" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                        Дашборд
                    </a>
                    <a href="/admin/moderation" class="menu-item active">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                        Модерация
                    </a>
                    <a href="/admin/reports" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"></path></svg>
                        Жалобы на отзывы
                    </a>
                    <a href="/admin/users" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        Пользователи
                    </a>
                    <a href="/admin/partners" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                        Партнеры
                    </a>
                    <a href="/admin/faq" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                        Входящие вопросы
                    </a>
                    <a href="/user/profile?tab=notifications" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        Уведомления
                    </a>
                </div>
            </aside>

            <main class="admin-content">
                <% if (typeof selectedItem !== 'undefined' && selectedItem) { %>
                    <!-- Детальная модерация -->
                    <div style="position: relative;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 35px; padding-bottom: 20px; border-bottom: 1px solid #f1f5f9;">
                            <div>
                                <h1 class="section-title" style="margin-bottom: 8px; font-size: 28px;">Проверка: <%= selectedItem.title %></h1>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <span style="font-size: 13px; color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;">ID: <%= selectedItem.id %></span>
                                    <span class="status-badge status-pending" style="height: 28px; font-size: 12px; padding: 0 14px; border-radius: 10px;">Ожидает проверки</span>
                                </div>
                            </div>
                            <a href="/admin/moderation" style="color: #635bff; text-decoration: none; font-weight: 700; font-size: 14px; display: flex; align-items: center; gap: 8px; padding: 10px 20px; background: #f0f0ff; border-radius: 12px;" onmouseover="this.style.transform='translateX(-5px)'; this.style.background='#e0dfff';" onmouseout="this.style.transform='translateX(0)'; this.style.background='#f0f0ff';">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                                К списку
                            </a>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-bottom: 30px;">
                            <div style="display: flex; flex-direction: column; gap: 25px;">
                                <div style="background: #f8fafc; padding: 30px; border-radius: 24px; border: 1px solid #f1f5f9;">
                                    <h3 style="font-size: 14px; color: #635bff; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 20px; font-weight: 800;">Информация об авторе</h3>
                                    <div style="display: grid; grid-template-columns: 1fr; gap: 18px;">
                                        <div><span style="color: #94a3b8; font-size: 12px; display: block; margin-bottom: 4px; font-weight: 700; text-transform: uppercase;">Имя</span><strong style="color: #1e293b; font-size: 16px;"><%= selectedItem.first_name %> <%= selectedItem.last_name %></strong></div>
                                        <div><span style="color: #94a3b8; font-size: 12px; display: block; margin-bottom: 4px; font-weight: 700; text-transform: uppercase;">Email</span><strong style="color: #1e293b; font-size: 16px;"><%= selectedItem.email %></strong></div>
                                        <div><span style="color: #94a3b8; font-size: 12px; display: block; margin-bottom: 4px; font-weight: 700; text-transform: uppercase;">Телефон</span><strong style="color: #1e293b; font-size: 16px;"><%= selectedItem.phone || '—' %></strong></div>
                                    </div>
                                </div>
                                <div style="background: #f8fafc; padding: 30px; border-radius: 24px; border: 1px solid #f1f5f9;">
                                    <h3 style="font-size: 14px; color: #635bff; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 20px; font-weight: 800;">Автоматическая проверка</h3>
                                    <div style="display: flex; flex-direction: column; gap: 12px;">
                                        <div style="display: flex; align-items: center; gap: 12px; color: <%= selectedItem.profanityCheck ? '#166534' : '#ef4444' %>; font-size: 14px; font-weight: 700; background: <%= selectedItem.profanityCheck ? '#f0fdf4' : '#fef2f2' %>; padding: 14px 20px; border-radius: 16px;">
                                            <div style="width: 28px; height: 28px; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><% if (selectedItem.profanityCheck) { %><polyline points="20 6 9 17 4 12"></polyline><% } else { %><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line><% } %></svg></div>
                                            <%= selectedItem.profanityCheck ? 'Текст без мата' : 'Обнаружен мат' %>
                                        </div>
                                        <div style="display: flex; align-items: center; gap: 12px; color: <%= selectedItem.formatCheck ? '#166534' : '#ef4444' %>; font-size: 14px; font-weight: 700; background: <%= selectedItem.formatCheck ? '#f0fdf4' : '#fef2f2' %>; padding: 14px 20px; border-radius: 16px;">
                                            <div style="width: 28px; height: 28px; border-radius: 50%; background: #fff; display: flex; align-items: center; justify-content: center;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><% if (selectedItem.formatCheck) { %><polyline points="20 6 9 17 4 12"></polyline><% } else { %><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line><% } %></svg></div>
                                            <%= selectedItem.formatCheck ? 'Формат соблюден' : 'Ошибка формата' %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div style="background: #f8fafc; padding: 25px; border-radius: 24px; border: 1px solid #f1f5f9; display: flex; flex-direction: column;">
                                <h3 style="font-size: 14px; color: #635bff; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 20px; font-weight: 800;">Медиа-контент</h3>
                                <% if (selectedItem.media_url) { %>
                                    <div style="flex: 1; border-radius: 20px; overflow: hidden; background: #fff; border: 1px solid #e2e8f0; cursor: zoom-in; min-height: 300px;" onclick="zoomMedia('<%= selectedItem.media_url %>', 'img')">
                                        <img src="<%= selectedItem.media_url %>" style="width: 100%; height: 100%; object-fit: cover; display: block;" alt="Media">
                                    </div>
                                <% } else { %>
                                    <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; background: #fff; border-radius: 20px; border: 2px dashed #e2e8f0; color: #cbd5e1; min-height: 300px;">
                                        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
                                        <span style="font-size: 14px; margin-top: 15px; font-weight: 700;">Изображение не загружено</span>
                                    </div>
                                <% } %>
                            </div>
                        </div>

                        <div style="background: #fff; padding: 35px; border-radius: 24px; border: 1px solid #f1f5f9; margin-bottom: 30px;">
                            <h3 style="font-size: 14px; color: #635bff; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 20px; font-weight: 800;">Описание</h3>
                            <div style="font-size: 17px; line-height: 1.8; color: #475569; white-space: pre-wrap;"><%= selectedItem.description %></div>
                        </div>

                        <div style="background: #f8fafc; padding: 35px; border-radius: 30px; border: 1px solid #f1f5f9;">
                            <h3 style="font-size: 16px; color: #1e293b; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 25px; text-align: center; font-weight: 800;">Принять решение</h3>
                            <form action="<%= selectedType === 'event' ? '/admin/moderation/update' : '/admin/moderation/proposal/update' %>" method="POST" id="mod-form">
                                <input type="hidden" name="id" value="<%= selectedItem.id %>">
                                <input type="hidden" name="status" id="mod-status" value="">
                                <div style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 30px;">
                                    <select class="template-select" id="template-select" onchange="document.getElementById('mod-comment').value = this.value">
                                        <option value="">Выберите готовый шаблон ответа...</option>
                                        <option value="Пожалуйста, добавьте более подробное описание.">Недостаточно описания</option>
                                        <option value="Название содержит недопустимые символы или слова.">Нарушение в названии</option>
                                        <option value="Данная идея уже была предложена ранее.">Дубликат идеи</option>
                                        <option value="Предложение не соответствует тематике платформы.">Не по теме</option>
                                    </select>
                                    <textarea name="moderation_comment" id="mod-comment" class="comment-area" placeholder="Напишите комментарий для автора..."></textarea>
                                </div>
                                <!-- Кнопки Одобрить и Отклонить - ряд через flex, ширина 180px, высота 56px, фиолетовый фон -->
                                <div class="decision-buttons">
                                    <button type="button" onclick="submitMod('approved')" class="btn-approve">Одобрить</button>
                                    <button type="button" onclick="submitMod('rejected')" class="btn-reject">Отклонить</button>
                                </div>
                            </form>
                        </div>
                    </div>
                    <script>
                        function submitMod(status) { document.getElementById('mod-status').value = status; document.getElementById('mod-form').submit(); }
                        function zoomMedia(src, type) {
                            const overlay = document.createElement('div');
                            overlay.style.cssText = 'position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:10000; display:flex; align-items:center; justify-content:center; cursor:zoom-out; backdrop-filter:blur(10px);';
                            overlay.onclick = () => overlay.remove();
                            const content = document.createElement('img');
                            content.src = src;
                            content.style.cssText = 'max-width:90%; max-height:90%; border-radius:20px;';
                            overlay.appendChild(content);
                            document.body.appendChild(overlay);
                        }
                    </script>
                <% } else { %>
                    <!-- Список модерации -->
                    <h2 class="section-title" style="font-size: 22px;">Мероприятия на модерации</h2>
                    <% if (events && events.length > 0) { %>
                        <div style="margin-bottom: 40px;">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Название</th>
                                        <th>Организатор</th>
                                        <th>Дата</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% events.forEach(event => { %>
                                        <tr>
                                            <td style="font-weight: 700; color: #1e293b;"><%= event.title %></td>
                                            <td><%= event.first_name %> <%= event.last_name %></td>
                                            <td><%= new Date(event.date).toLocaleDateString('ru-RU') %></td>
                                            <td>
                                                <div class="btn-group">
                                                    <a href="/admin/moderation?id=<%= event.id %>&type=event" class="btn-action btn-view">Проверить</a>
                                                    <form action="/admin/moderation/event/delete" method="POST" style="display: inline;">
                                                        <input type="hidden" name="id" value="<%= event.id %>">
                                                        <button type="submit" class="btn-action btn-delete" onclick="return confirm('Удалить мероприятие?')">Удалить</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="empty-state" style="margin-bottom: 40px;"><p>Нет мероприятий, ожидающих модерации.</p></div>
                    <% } %>

                    <h2 class="section-title" style="font-size: 22px;">Предложения на модерации</h2>
                    <% if (proposals && proposals.length > 0) { %>
                        <div style="margin-bottom: 40px;">
                            <table class="admin-table">
                                <thead>
                                    <tr>
                                        <th>Название</th>
                                        <th>Автор</th>
                                        <th>Категория</th>
                                        <th>Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% proposals.forEach(proposal => { %>
                                        <tr>
                                            <td style="font-weight: 700; color: #1e293b;"><%= proposal.title %></td>
                                            <td><%= proposal.first_name %> <%= proposal.last_name %></td>
                                            <td><%= proposal.category %></td>
                                            <td>
                                                <div class="btn-group">
                                                    <a href="/admin/moderation?id=<%= proposal.id %>&type=proposal" class="btn-action btn-view">Проверить</a>
                                                    <form action="/admin/moderation/proposal/delete" method="POST" style="display: inline;">
                                                        <input type="hidden" name="id" value="<%= proposal.id %>">
                                                        <button type="submit" class="btn-action btn-delete" onclick="return confirm('Удалить предложение?')">Удалить</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <div class="empty-state" style="margin-bottom: 40px;"><p>Нет предложений, ожидающих модерации.</p></div>
                    <% } %>

                    <hr>

                    <h2 class="section-title" style="font-size: 22px;">Управление контентом</h2>
                    <div style="display: flex; gap: 10px; margin-bottom: 20px;">
                        <button onclick="switchTab('all')" class="tab-btn" id="btn-all" style="background: <%= currentRole === 'all' ? '#635bff' : '#f1f5f9' %>; color: <%= currentRole === 'all' ? '#fff' : '#64748b' %>;">Все</button>
                        <button onclick="switchTab('event')" class="tab-btn" id="btn-event" style="background: <%= currentRole === 'event' ? '#635bff' : '#f1f5f9' %>; color: <%= currentRole === 'event' ? '#fff' : '#64748b' %>;">Мероприятия</button>
                        <button onclick="switchTab('proposal')" class="tab-btn" id="btn-proposal" style="background: <%= currentRole === 'proposal' ? '#635bff' : '#f1f5f9' %>; color: <%= currentRole === 'proposal' ? '#fff' : '#64748b' %>;">Предложения</button>
                    </div>

                    <div id="tab-content-event" style="display: <%= (currentRole === 'all' || currentRole === 'event') ? 'block' : 'none' %>;">
                        <h3 style="font-size: 18px; margin-bottom: 15px;">Все мероприятия</h3>
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Организатор</th>
                                    <th>Статус</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% allEvents.forEach(event => { %>
                                    <tr>
                                        <td style="font-weight: 700; color: #1e293b;"><%= event.title %></td>
                                        <td><%= event.first_name %> <%= event.last_name %></td>
                                        <td>
                                            <% if (event.status === 'approved') { %>
                                                <span class="status-badge status-approved">Одобрено</span>
                                            <% } else if (event.status === 'rejected') { %>
                                                <span class="status-badge status-rejected">Отклонено</span>
                                            <% } else if (event.status === 'pending') { %>
                                                <span class="status-badge status-pending">На модерации</span>
                                            <% } else if (event.status === 'requires_changes') { %>
                                                <span class="status-badge status-requires_changes">Требует изменений</span>
                                            <% } else { %>
                                                <span class="status-badge"><%= event.status %></span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <div class="btn-group">
                                                <form action="/admin/moderation/event/delete" method="POST" style="display: inline;">
                                                    <input type="hidden" name="id" value="<%= event.id %>">
                                                    <button type="submit" class="btn-action btn-delete" onclick="return confirm('Удалить мероприятие?')">Удалить</button>
                                                </form>
                                                <a href="/events/<%= event.id %>" class="btn-action btn-view" target="_blank">Просмотр</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <div id="tab-content-proposal" style="display: <%= (currentRole === 'all' || currentRole === 'proposal') ? 'block' : 'none' %>;">
                        <h3 style="font-size: 18px; margin: 30px 0 15px;">Все предложения</h3>
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Автор</th>
                                    <th>Статус</th>
                                    <th>Голосов</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% allProposals.forEach(proposal => { %>
                                    <tr>
                                        <td style="font-weight: 700; color: #1e293b;"><%= proposal.title %></td>
                                        <td><%= proposal.first_name %> <%= proposal.last_name %></td>
                                        <td>
                                            <% if (proposal.status === 'voting') { %>
                                                <span class="status-badge status-voting">Голосование</span>
                                            <% } else if (proposal.status === 'moderation') { %>
                                                <span class="status-badge status-moderation">На модерации</span>
                                            <% } else if (proposal.status === 'rejected') { %>
                                                <span class="status-badge status-rejected">Отклонено</span>
                                            <% } else if (proposal.status === 'in_progress') { %>
                                                <span class="status-badge status-in_progress">В работе</span>
                                            <% } else if (proposal.status === 'completed') { %>
                                                <span class="status-badge status-completed">Завершено</span>
                                            <% } else if (proposal.status === 'approved') { %>
                                                <span class="status-badge status-approved">Одобрено</span>
                                            <% } else { %>
                                                <span class="status-badge"><%= proposal.status %></span>
                                            <% } %>
                                        </td>
                                        <td style="text-align: center;"><%= proposal.votes_count || 0 %></td>
                                        <td>
                                            <div class="btn-group">
                                                <form action="/admin/moderation/proposal/delete" method="POST" style="display: inline;">
                                                    <input type="hidden" name="id" value="<%= proposal.id %>">
                                                    <button type="submit" class="btn-action btn-delete" onclick="return confirm('Удалить предложение?')">Удалить</button>
                                                </form>
                                                <a href="/admin/moderation?id=<%= proposal.id %>&type=proposal" class="btn-action btn-view">Проверить</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <script>
                        function switchTab(role) {
                            const eventContent = document.getElementById('tab-content-event');
                            const proposalContent = document.getElementById('tab-content-proposal');
                            const btns = {
                                all: document.getElementById('btn-all'),
                                event: document.getElementById('btn-event'),
                                proposal: document.getElementById('btn-proposal')
                            };
                            Object.values(btns).forEach(btn => {
                                btn.style.background = '#f1f5f9';
                                btn.style.color = '#64748b';
                            });
                            btns[role].style.background = '#635bff';
                            btns[role].style.color = '#fff';
                            if (role === 'all') {
                                eventContent.style.display = 'block';
                                proposalContent.style.display = 'block';
                            } else if (role === 'event') {
                                eventContent.style.display = 'block';
                                proposalContent.style.display = 'none';
                            } else {
                                eventContent.style.display = 'none';
                                proposalContent.style.display = 'block';
                            }
                            const newUrl = window.location.pathname + '?role=' + role;
                            window.history.replaceState({path: newUrl}, '', newUrl);
                        }
                    </script>
                <% } %>
            </main>
        </div>
    </div>
    <%- include('../partials/footer') %>
</body>
</html>