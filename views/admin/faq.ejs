<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Входящие вопросы - Админ-панель | Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .admin-layout { display: grid; grid-template-columns: 280px 1fr; gap: 30px; padding: 40px 0; align-items: start; }
        .admin-sidebar { background: #fff; border-radius: 24px; padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.04); position: sticky; top: 100px; }
        .admin-menu { display: flex; flex-direction: column; gap: 5px; }
        .menu-item { display: flex; align-items: center; gap: 12px; padding: 12px 20px; border-radius: 12px; text-decoration: none; color: #64748b; font-family: 'Manrope', sans-serif; font-weight: 600; font-size: 15px; transition: 0.3s; }
        .menu-item svg { width: 18px; height: 18px; stroke-width: 2px; }
        .menu-item:hover { color: #635bff; background: #f8fafc; }
        .menu-item.active { background: #635bff; color: #fff; box-shadow: 0 4px 12px rgba(99, 91, 255, 0.25); }
        .admin-content { background: #fff; border-radius: 24px; padding: 40px; box-shadow: 0 10px 30px rgba(0,0,0,0.04); min-height: 500px; }
        .section-title { font-size: 28px; font-weight: 800; margin-bottom: 25px; color: #1e293b; }
        .admin-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; }
        .admin-table th { text-align: left; padding: 15px 20px; color: #94a3b8; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
        .admin-table tr { background: #f8fafc; transition: 0.3s; }
        .admin-table tr:hover { transform: scale(1.01); box-shadow: 0 5px 15px rgba(0,0,0,0.03); }
        .admin-table td { padding: 20px; }
        .admin-table td:first-child { border-radius: 16px 0 0 16px; }
        .admin-table td:last-child { border-radius: 0 16px 16px 0; }
        .status-badge { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700; display: inline-block; }
        .status-pending { background: #fef3c7; color: #d97706; }
        .status-replied { background: #dcfce7; color: #16a34a; }
        .btn-reply { background: #635bff; color: #fff; border: none; padding: 6px 16px; border-radius: 20px; font-weight: 600; cursor: pointer; font-size: 12px; }
        .btn-reply:hover { background: #4f46e5; }
        .btn-delete { background: #fee2e2; color: #ef4444; border: none; padding: 6px 16px; border-radius: 20px; font-weight: 600; cursor: pointer; font-size: 12px; }
        .btn-delete:hover { background: #fecaca; }
        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); backdrop-filter: blur(4px); align-items: center; justify-content: center; }
        .modal.active { display: flex; }
        .modal-content { background-color: #fff; padding: 30px; border-radius: 24px; width: 500px; max-width: 90%; }
        .modal-content h3 { font-size: 20px; font-weight: 800; margin-bottom: 15px; }
        .modal-content textarea { width: 100%; padding: 12px; border: 1px solid #e2e8f0; border-radius: 12px; font-family: inherit; resize: vertical; margin: 15px 0; }
        .modal-actions { display: flex; gap: 12px; justify-content: flex-end; }
        .empty-state { text-align: center; padding: 60px 40px; background: #f8fafc; border-radius: 20px; color: #94a3b8; }
        @media (max-width: 992px) { .admin-layout { grid-template-columns: 1fr; } .admin-sidebar { position: static; } }
    </style>
</head>
<body>
    <%- include('../partials/header') %>
    <div class="container">
        <div class="admin-layout">
            <aside class="admin-sidebar">
                <div class="admin-menu">
                    <a href="/admin/dashboard" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                        Дашборд
                    </a>
                    <a href="/admin/moderation" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                        Модерация
                    </a>
                    <a href="/admin/reports" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 8v4m0 4h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"></path></svg>
                        Жалобы на отзывы
                    </a>
                    <a href="/admin/users" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                        Пользователи
                    </a>
                    <a href="/admin/partners" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                        Партнеры
                    </a>
                    <a href="/admin/faq" class="menu-item active">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
                        Входящие вопросы
                    </a>
                    <a href="/user/profile?tab=notifications" class="menu-item">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        Уведомления
                    </a>
                </div>
            </aside>
            <main class="admin-content">                
                <% if (messages && messages.length > 0) { %>
                    <div style="overflow-x: auto;">
                        <table class="admin-table">
                            <thead>
                                <tr><th>Дата</th><th>Отправитель</th><th>Сообщение</th><th>Статус</th><th>Действия</th></tr>
                            </thead>
                            <tbody>
                                <% messages.forEach(msg => { %>
                                    <tr>
                                        <td style="font-size: 13px; color: #64748b;"><%= new Date(msg.created_at).toLocaleDateString('ru-RU') %></td>
                                        <td><div style="font-weight: 700; color: #1e293b;"><%= msg.name %></div><div style="font-size: 12px; color: #64748b;"><%= msg.phone %></div><div style="font-size: 12px; color: #64748b;"><%= msg.email %></div></td>
                                        <td style="max-width: 350px; font-size: 14px; color: #475569;"><%= msg.message %></td>
                                        <td><span class="status-badge <%= msg.status === 'pending' ? 'status-pending' : 'status-replied' %>"><%= msg.status === 'pending' ? 'Ожидает' : 'Отвечено' %></span></td>
                                        <td><div style="display: flex; gap: 8px;"><button class="btn-reply" onclick="openReplyModal('<%= msg.id %>', '<%= msg.message.replace(/'/g, "\\'") %>')">Ответить</button><form action="/admin/faq/delete-message" method="POST" onsubmit="return confirm('Удалить сообщение?')" style="display:inline;"><input type="hidden" name="messageId" value="<%= msg.id %>"><button type="submit" class="btn-delete">Удалить</button></form></div></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="empty-state"><div style="font-size: 16px; font-weight: 600;">Нет входящих вопросов</div><div style="font-size: 14px; margin-top: 8px;">Вопросы из формы обратной связи появятся здесь</div></div>
                <% } %>
            </main>
        </div>
    </div>
    <div id="replyModal" class="modal"><div class="modal-content"><h3>Ответ на вопрос</h3><p id="originalMessage" style="background: #f8fafc; padding: 12px; border-radius: 12px; font-style: italic; color: #64748b;"></p><form action="/admin/faq/reply" method="POST"><input type="hidden" name="messageId" id="replyMessageId"><textarea name="reply" rows="5" placeholder="Напишите ответ..." required></textarea><div class="modal-actions"><button type="button" class="btn-delete" onclick="closeReplyModal()">Отмена</button><button type="submit" class="btn-reply">Отправить ответ</button></div></form></div></div>
    <%- include('../partials/footer') %>
    <script>
        function openReplyModal(id, message) { document.getElementById('replyMessageId').value = id; document.getElementById('originalMessage').innerText = message; document.getElementById('replyModal').classList.add('active'); }
        function closeReplyModal() { document.getElementById('replyModal').classList.remove('active'); }
        window.onclick = function(event) { const modal = document.getElementById('replyModal'); if (event.target === modal) closeReplyModal(); }
    </script>
</body>
</html>