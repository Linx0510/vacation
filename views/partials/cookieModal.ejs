<div id="cookie-banner" style="position: fixed; bottom: 30px; left: 30px; right: 30px; background: #fff; padding: 24px; border-radius: 24px; box-shadow: 0 20px 50px rgba(0,0,0,0.15); z-index: 10001; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;">
    <div style="display: flex; align-items: center; gap: 24px; flex: 1;">
        <div class="cookie-visual" style="flex-shrink: 0; position: relative;">
            <style>
                @keyframes cookieFloat {
                    0% { transform: translateY(0) rotate(0deg); }
                    50% { transform: translateY(-5px) rotate(5deg); }
                    100% { transform: translateY(0) rotate(0deg); }
                }
                .cookie-svg {
                    filter: drop-shadow(0 10px 15px rgba(210, 180, 140, 0.4));
                    animation: cookieFloat 4s ease-in-out infinite;
                }
                .cookie-glow {
                    position: absolute;
                    top: 50%;
                    left: 50%;
                    transform: translate(-50%, -50%);
                    width: 80px;
                    height: 80px;
                    background: radial-gradient(circle, rgba(210, 180, 140, 0.2) 0%, rgba(210, 180, 140, 0) 70%);
                    z-index: -1;
                }
            </style>
            <div class="cookie-glow"></div>
            <svg class="cookie-svg" width="70" height="70" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <filter id="cookieShadow" x="-20%" y="-20%" width="140%" height="140%">
                        <feGaussianBlur in="SourceAlpha" stdDeviation="2"/>
                        <feOffset dx="1" dy="2" result="offsetblur"/>
                        <feComponentTransfer>
                            <feFuncA type="linear" slope="0.2"/>
                        </feComponentTransfer>
                        <feMerge>
                            <feMergeNode/>
                            <feMergeNode in="SourceGraphic"/>
                        </feMerge>
                    </filter>
                </defs>
                <!-- Тело печеньки -->
                <path d="M50 10 C25 10 10 25 10 50 C10 75 25 90 50 90 C75 90 90 75 90 50 C90 45 85 40 80 35 C85 30 85 20 75 15 C70 10 60 10 50 10Z" fill="#D2B48C" filter="url(#cookieShadow)"/>
                <!-- Крошки/Шоколад -->
                <circle cx="35" cy="35" r="5" fill="#5D4037"/>
                <circle cx="65" cy="40" r="4" fill="#5D4037"/>
                <circle cx="45" cy="65" r="6" fill="#5D4037"/>
                <circle cx="70" cy="65" r="3" fill="#5D4037"/>
                <circle cx="55" cy="25" r="4" fill="#5D4037"/>
                <!-- Текстура -->
                <path d="M20 50 Q30 45 40 50" stroke="#C19A6B" stroke-width="2" fill="none" opacity="0.5"/>
                <path d="M60 75 Q70 70 80 75" stroke="#C19A6B" stroke-width="2" fill="none" opacity="0.5"/>
            </svg>
        </div>
        <div class="cookie-text" style="flex: 1;">
            <h4 style="margin: 0 0 4px; font-size: 18px; font-weight: 800; color: #1e293b;">Мы используем Cookie</h4>
            <p style="margin: 0; font-size: 14px; color: #64748b; line-height: 1.5;">Продолжая использовать наш сайт, вы соглашаетесь на обработку персональных данных<br>и использование файлов cookie.</p>
        </div>
    </div>
    <div class="cookie-actions">
        <button id="accept-cookies-fast" style="padding: 10px 24px; background: #635bff; color: #fff; border: none; border-radius: 100px; font-weight: 700; cursor: pointer; transition: 0.3s;">Принять всё</button>
    </div>
</div>

<script>
    console.log('Cookie скрипт загружен');
    
    var banner = document.getElementById('cookie-banner');
    console.log('Баннер cookie найден');
    
    var saved = localStorage.getItem('cookie_consent');
    console.log('Сохраненное согласие:', saved);
    
    if (saved === 'true') {
        if (banner) {
            banner.style.display = 'none';
            console.log('Баннер cookie скрыт (согласие уже есть)');
        }
    } else {
        if (banner) {
            banner.style.display = 'flex';
            console.log('Баннер cookie показан');
        }
    }
    
    var btn = document.getElementById('accept-cookies-fast');
    if (btn) {
        btn.onclick = function() {
            localStorage.setItem('cookie_consent', 'true');
            if (banner) {
                banner.style.display = 'none';
            }
            console.log('Согласие на cookie получено, баннер скрыт');
        };
    }
</script>