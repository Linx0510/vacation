<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Восстановление пароля - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
</head>
<body>
    <%- include('../partials/header') %>

    <main class="auth-page">
        <div class="auth-container">
            <h1>Восстановление</h1>
            <p class="auth-subtitle">Введите ваш Email, и мы отправим инструкции по сбросу пароля</p>
            
            <% if (error && error.length > 0) { %>
                <div class="alert alert-danger"><%= error %></div>
            <% } %>
            <% if (success && success.length > 0) { %>
                <div class="alert alert-success"><%= success %></div>
            <% } %>
            
            <form action="/auth/forgot-password" method="POST">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="example@mail.com" required>
                </div>
                <button type="submit" class="btn-auth">Отправить инструкции</button>
            </form>
            
            <div class="auth-footer">
                <p>Вспомнили пароль? <a href="/auth/login">Войти</a></p>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script src="/js/validation.js"></script>
</body>
</html>
