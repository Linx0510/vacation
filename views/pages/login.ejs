<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вход - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        body { font-family: 'Manrope', sans-serif; }
        h1, h2, h3 { font-family: 'Bellota', cursive; }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <main class="auth-page container" style="padding: 40px 20px; display: flex; justify-content: center; align-items: center; min-height: 70vh;">
        <div class="auth-container glass-card animate-fade-in" style="width: 100%; max-width: 450px; padding: 40px; background: #fff;">
            <h1 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 10px; text-align: center;">С возвращением!</h1>
            <p class="auth-subtitle" style="color: #64748b; text-align: center; margin-bottom: 40px;">Войдите в свой аккаунт, чтобы продолжить</p>
            
            <% if (error && error.length > 0) { %>
                <div class="alert alert-danger" style="background: #fee2e2; color: #ef4444; padding: 15px; border-radius: 12px; margin-bottom: 25px; font-weight: 600; font-size: 14px; text-align: center;">
                    <%= error %>
                </div>
            <% } %>
            <% if (success && success.length > 0) { %>
                <div class="alert alert-success" style="background: #d1fae5; color: #10b981; padding: 15px; border-radius: 12px; margin-bottom: 25px; font-weight: 600; font-size: 14px; text-align: center;">
                    <%= success %>
                </div>
            <% } %>
            
            <form action="/auth/login" method="POST" class="vk-form">
                <div class="form-group" style="margin-bottom: 20px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 700; font-size: 14px;">Email</label>
                    <input type="email" name="email" placeholder="example@mail.com" required style="width: 100%; padding: 12px 15px; border-radius: 12px; border: 1px solid #e2e8f0; font-family: inherit;">
                </div>
                <div class="form-group" style="margin-bottom: 30px;">
                    <label style="display: block; margin-bottom: 8px; font-weight: 700; font-size: 14px;">Пароль</label>
                    <input type="password" name="password" placeholder="••••••••" required style="width: 100%; padding: 12px 15px; border-radius: 12px; border: 1px solid #e2e8f0; font-family: inherit;">
                </div>
                <button type="submit" class="btn-vk-primary" style="width: 100%; margin-bottom: 10px;">Войти</button>
            </form>
            
            <div class="auth-footer" style="text-align: center; border-top: 1px solid #f1f5f9; padding-top: 10px;">
                <p style="color: #64748b; font-size: 15px; margin-bottom: 5px;">Нет аккаунта? <a href="/auth/register" style="color: var(--primary-purple); text-decoration: none; font-weight: 700;">Зарегистрироваться</a></p>
                <p style="margin: 0;"><a href="/auth/forgot-password" style="font-size: 13px; color: #94a3b8; text-decoration: none;">Забыли пароль?</a></p>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>
    <script src="/js/validation.js"></script>
</body>
</html>
