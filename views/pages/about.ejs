    <script src="https://unpkg.com/imask"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const phoneAbout = document.getElementById('phone-about');
            if (phoneAbout) { IMask(phoneAbout, { mask: '+{7} (000) 000-00-00' }); }
            
            const slider = document.getElementById('infinite-slider');
            if (slider) { slider.innerHTML += slider.innerHTML; }

            const stats = document.querySelectorAll('.stat-number');
            stats.forEach(stat => {
                const updateCount = () => {
                    const target = +stat.getAttribute('data-target');
                    const count = +stat.innerText;
                    const speed = target / 100;
                    if (count < target) {
                        stat.innerText = Math.ceil(count + speed);
                        setTimeout(updateCount, 20);
                    } else {
                        stat.innerText = target;
                    }
                };
                const statsObserver = new IntersectionObserver((entries) => {
                    if(entries[0].isIntersecting) { updateCount(); statsObserver.unobserve(stat); }
                });
                statsObserver.observe(stat);
            });
        });
    </script>
