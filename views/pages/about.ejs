<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>О нас - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
        <style>
            body { font-family: 'Manrope', sans-serif; }
            h1, h2, h3 { font-family: 'Bellota', cursive; margin-top: 0 !important; }
        </style></head>
<body class="about-page-body">
    <%- include('../partials/header') %>

    <main class="about-main">
        <!-- Hero Section -->
        <section class="hero-new" style="margin-bottom: 80px; min-height: 450px; display: flex; align-items: center; justify-content: center; text-align: center; position: relative; overflow: hidden; background: var(--primary-purple); border-radius: 40px;">
            <div class="hero-decorations" style="position: absolute; width: 100%; height: 100%; top: 0; left: 0; pointer-events: none;">
                <div class="star-line" style="top: 10%; left: 20%; animation-delay: 0s;"></div>
                <div class="star-line" style="top: 30%; left: 50%; animation-delay: 2s;"></div>
                <div class="star-line" style="top: 15%; left: 80%; animation-delay: 4s;"></div>
                <div class="decor-item" style="top: 15%; left: 10%;">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <div class="decor-item" style="top: 10%; right: 15%; animation-delay: -2s;">
                    <svg width="35" height="35" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.3"><circle cx="12" cy="12" r="10"/><path d="M12 8v8M8 12h8"/></svg>
                </div>
                <div class="decor-item" style="bottom: 15%; left: 15%; animation-delay: -4s;">
                    <svg width="45" height="45" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.4"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                </div>
                <div class="decor-item" style="bottom: 10%; right: 10%; animation-delay: -1s;">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.3"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                </div>
                <svg style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0.2;">
                    <path d="M 0 100 Q 250 50 500 100 T 1000 100" stroke="white" stroke-width="2" fill="none" class="line-anim" />
                    <path d="M 0 300 Q 250 350 500 300 T 1000 300" stroke="white" stroke-width="2" fill="none" class="line-anim" style="animation-delay: -5s;" />
                </svg>
            </div>
            <div class="container" style="position: relative; z-index: 10;">
                <h1 style="font-size: 4.5rem; font-weight: 800; color: #fff; margin: 0; line-height: 1.2; font-family: 'Bellota', cursive;">
                    События, <br> рождённые людьми
                </h1>
            </div>
        </section>

        <style>
            .star-line { position: absolute; width: 150px; height: 2px; background: linear-gradient(90deg, rgba(255,255,255,0.8), transparent); transform: rotate(-45deg); animation: starShoot 4s linear infinite; opacity: 0; }
            @keyframes starShoot { 0% { transform: translate(300px, -300px) rotate(-45deg); opacity: 0; } 10% { opacity: 1; } 30% { transform: translate(-600px, 600px) rotate(-45deg); opacity: 0; } 100% { transform: translate(-600px, 600px) rotate(-45deg); opacity: 0; } }
            .decor-item { position: absolute; animation: itemFloat 6s infinite ease-in-out; }
            @keyframes itemFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
            .line-anim { stroke-dasharray: 1000; stroke-dashoffset: 1000; animation: lineFlow 15s linear infinite; }
            @keyframes lineFlow { to { stroke-dashoffset: 0; } }
        </style>

        <div class="container">
            <!-- Mission Section -->
            <section class="about-mission-horizontal" style="margin: 120px 0; position: relative; padding-bottom: 40px; width: 100vw; margin-left: calc(-50vw + 50%);">
                <div class="container">
                    <div style="margin-bottom: 60px;">
                        <h2 style="font-size: 4rem; font-weight: 800; margin: 0; font-family: 'Bellota', cursive; letter-spacing: -2px; color: var(--text-dark);">Наша главная <span style="color: var(--primary-purple); position: relative;">цель<svg style="position: absolute; bottom: -10px; left: 0; width: 100%; height: 12px;" viewBox="0 0 100 12" preserveAspectRatio="none"><path d="M0,10 Q50,0 100,10" stroke="var(--primary-purple)" stroke-width="4" fill="none" stroke-linecap="round"/></svg></span></h2>
                        <p style="color: #64748b; font-size: 20px; margin-top: 20px; font-weight: 500;">Создаем будущее ивентов вместе с вами</p>
                    </div>
                </div>
                <div class="mission-outer-container" style="width: 100%; overflow: hidden; position: relative;">
                    <div class="mission-scroll-wrapper" id="infinite-slider" style="display: flex; gap: 30px; padding: 20px 0 80px; width: max-content;">
                        <div class="mission-card-new" style="flex: 0 0 450px; background: #f3f0ff; border-radius: 40px; padding: 50px; position: relative; overflow: hidden; min-height: 500px; display: flex; flex-direction: column; border: 1px solid rgba(99, 91, 255, 0.1);">
                            <div class="card-bg-icon" style="position: absolute; top: 30px; right: 30px; opacity: 0.1;"><svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="var(--primary-purple)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg></div>
                            <div class="card-tag" style="background: var(--primary-purple); color: #fff; padding: 5px 14px; border-radius: 100px; font-size: 11px; font-weight: 800; text-transform: uppercase; width: fit-content; margin-bottom: 25px; letter-spacing: 1px;">История</div>
                            <h3 style="font-size: 3rem; font-weight: 800; color: var(--primary-purple); margin-bottom: 25px; font-family: 'Bellota', cursive; line-height: 1.1; letter-spacing: -1px;">Создаём <br>историю</h3>
                            <p style="font-size: 18px; color: #4b5563; line-height: 1.6; margin-bottom: 40px; font-family: 'Manrope', sans-serif; font-weight: 500;">Наша главная цель — создавать сервис, который вызывает доверие и преданность у организаторов и пользователей на долгие годы.</p>
                        </div>
                        <div class="mission-card-new" style="flex: 0 0 450px; background: #ffffff; border-radius: 40px; padding: 50px; position: relative; overflow: hidden; min-height: 500px; display: flex; flex-direction: column; border: none;">
                            <div class="card-bg-icon" style="position: absolute; top: 30px; right: 30px; opacity: 0.1;"><svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="#1e293b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path></svg></div>
                            <div class="card-tag" style="background: #1e293b; color: #fff; padding: 5px 14px; border-radius: 100px; font-size: 11px; font-weight: 800; text-transform: uppercase; width: fit-content; margin-bottom: 25px; letter-spacing: 1px;">Скорость</div>
                            <h3 style="font-size: 3rem; font-weight: 800; color: #1e293b; margin-bottom: 25px; font-family: 'Bellota', cursive; line-height: 1; letter-spacing: -1px;">Без <br>бюрократии</h3>
                            <p style="font-size: 18px; color: #4b5563; line-height: 1.6; margin-bottom: 40px; font-family: 'Manrope', sans-serif; font-weight: 500;">Организаторы живут тем, что делают. А мы строим для них удобную платформу без очередей, без скрытых комиссий и без ожидания.</p>
                        </div>
                        <div class="mission-card-new" style="flex: 0 0 450px; background: #f3f0ff; border-radius: 40px; padding: 50px; position: relative; overflow: hidden; min-height: 500px; display: flex; flex-direction: column; border: 1px solid rgba(99, 91, 255, 0.1);">
                            <div class="card-bg-icon" style="position: absolute; top: 30px; right: 30px; opacity: 0.1;"><svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="var(--primary-purple)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"></path><path d="M9 12H4s.5-1 1-4 1.5-3 1.5-3L9 12z"></path></svg></div>
                            <div class="card-tag" style="background: var(--primary-purple); color: #fff; padding: 5px 14px; border-radius: 100px; font-size: 11px; font-weight: 800; text-transform: uppercase; width: fit-content; margin-bottom: 25px; letter-spacing: 1px;">Рост</div>
                            <h3 style="font-size: 3rem; font-weight: 800; color: var(--primary-purple); margin-bottom: 25px; font-family: 'Bellota', cursive; line-height: 1; letter-spacing: -1px;">Долой <br>рутину</h3>
                            <p style="font-size: 18px; color: #4b5563; line-height: 1.6; margin-bottom: 40px; font-family: 'Manrope', sans-serif; font-weight: 500;">Мы хотим освобождать организаторов от рутины и помогать расти их мероприятиям по всей стране.</p>
                        </div>
                        <div class="mission-card-new" style="flex: 0 0 450px; background: #ffffff; border-radius: 40px; padding: 50px; position: relative; overflow: hidden; min-height: 500px; display: flex; flex-direction: column; border: 2px solid #f1f5f9;">
                            <div class="card-bg-icon" style="position: absolute; top: 30px; right: 30px; opacity: 0.1;"><svg width="100" height="100" viewBox="0 0 24 24" fill="none" stroke="#1e293b" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle></svg></div>
                            <div class="card-tag" style="background: #1e293b; color: #fff; padding: 5px 14px; border-radius: 100px; font-size: 11px; font-weight: 800; text-transform: uppercase; width: fit-content; margin-bottom: 25px; letter-spacing: 1px;">Вызов</div>
                            <h3 style="font-size: 3rem; font-weight: 800; color: #1e293b; margin-bottom: 25px; font-family: 'Bellota', cursive; line-height: 1; letter-spacing: -1px;">Принимаем <br>вызов</h3>
                            <p style="font-size: 18px; color: #4b5563; line-height: 1.6; margin-bottom: 40px; font-family: 'Manrope', sans-serif; font-weight: 500;">Наши организаторы превращают чужие проблемы в свои. Поэтому и мы ставим перед собой агрессивные цели.</p>
                        </div>
                    </div>
                </div>
            </section>

            <style>
                .mission-scroll-wrapper { animation: scrollInfinite 40s linear infinite; }
                .mission-scroll-wrapper:hover { animation-play-state: paused; }
                @keyframes scrollInfinite { 0% { transform: translateX(0); } 100% { transform: translateX(calc(-450px * 4 - 30px * 4)); } }
                .mission-card-new { transition: all 0.4s ease; }
                .mission-card-new:hover { transform: translateY(-10px); border-color: var(--primary-purple); }
            </style>

            <!-- Stats Section -->
            <section class="about-stats-new" style="background: var(--primary-purple); padding: 120px 0; margin: 100px 0; width: 100vw; margin-left: calc(-50vw + 50%); position: relative; overflow: hidden;">
                <div class="container" style="position: relative; z-index: 2;">
                    <h2 style="text-align: center; font-size: 3.5rem; font-weight: 800; margin-bottom: 80px; font-family: 'Manrope', sans-serif; color: #fff; letter-spacing: -1.5px;">Цифры, которые нас <span style="color: #fff; font-family: 'Bellota', cursive; position: relative; display: inline-block;">вдохновляют<svg style="position: absolute; bottom: -8px; left: 0; width: 100%; height: 12px;" viewBox="0 0 100 12" preserveAspectRatio="none"><path d="M0,10 Q50,0 100,10" stroke="white" stroke-width="6" fill="none" stroke-linecap="round"/></svg></span></h2>
                    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; text-align: center;">
                        <div class="stat-item" style="background: transparent; border: none;">
                            <div style="display: flex; align-items: baseline; justify-content: center; gap: 5px; margin-bottom: 15px; min-width: 200px;">
                                <span class="stat-number" data-target="500" style="font-size: 6rem; font-weight: 800; color: #fff; font-family: 'Manrope', sans-serif; line-height: 1; display: inline-block; min-width: 1.2em; text-align: right;">0</span>
                                <span style="font-size: 3.5rem; font-weight: 800; color: rgba(255,255,255,0.6); font-family: 'Bellota', cursive;">+</span>
                            </div>
                            <p style="font-size: 18px; color: rgba(255,255,255,0.9); font-weight: 600; margin: 0; text-transform: uppercase; letter-spacing: 1.5px;">мероприятий проведено</p>
                        </div>
                        <div class="stat-item" style="background: transparent; border: none;">
                            <div style="display: flex; align-items: baseline; justify-content: center; gap: 5px; margin-bottom: 15px; min-width: 200px;">
                                <span class="stat-number" data-target="10000" style="font-size: 6rem; font-weight: 800; color: #fff; font-family: 'Manrope', sans-serif; line-height: 1; display: inline-block; min-width: 2.2em; text-align: right;">0</span>
                                <span style="font-size: 3.5rem; font-weight: 800; color: rgba(255,255,255,0.6); font-family: 'Bellota', cursive;">+</span>
                            </div>
                            <p style="font-size: 18px; color: rgba(255,255,255,0.9); font-weight: 600; margin: 0; text-transform: uppercase; letter-spacing: 1.5px;">пользователей с нами</p>
                        </div>
                        <div class="stat-item" style="background: transparent; border: none;">
                            <div style="display: flex; align-items: baseline; justify-content: center; gap: 5px; margin-bottom: 15px; min-width: 200px;">
                                <span class="stat-number" data-target="85" style="font-size: 6rem; font-weight: 800; color: #fff; font-family: 'Manrope', sans-serif; line-height: 1; display: inline-block; min-width: 1em; text-align: right;">0</span>
                                <span style="font-size: 3.5rem; font-weight: 800; color: rgba(255,255,255,0.6); font-family: 'Bellota', cursive;">%</span>
                            </div>
                            <p style="font-size: 18px; color: rgba(255,255,255,0.9); font-weight: 600; margin: 0; text-transform: uppercase; letter-spacing: 1.5px;">организаторов возвращаются</p>
                        </div>
                    </div>
                </div>
            </section>

            <style>
                .stat-card-minimal { text-align: center; padding: 40px; }
                .stat-card-minimal .stat-number, .stat-card-minimal span, .stat-card-minimal p { color: #ffffff !important; opacity: 1 !important; visibility: visible !important; }
                .stat-card-minimal:hover { transform: none !important; background: transparent !important; }
            </style>

            <!-- Love Section -->
            <section class="about-love container" style="margin-bottom: 120px; text-align: center; position: relative;">
                <div class="glass-card" style="padding: 80px; border-radius: 40px; background: linear-gradient(135deg, #fff 0%, #f3f0ff 100%); border: 2px solid var(--primary-purple); position: relative; overflow: hidden;">
                    <div class="bg-decor-icon" style="top: 15%; left: 10%; animation-delay: 0s;"><svg width="12" height="12" viewBox="0 0 24 24" fill="var(--primary-purple)" class="twinkle-star"><path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41L12 0Z"/></svg></div>
                    <div class="bg-decor-icon" style="top: 25%; right: 15%; animation-delay: 1s;"><svg width="8" height="8" viewBox="0 0 24 24" fill="var(--primary-purple)" class="twinkle-star"><path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41L12 0Z"/></svg></div>
                    <div class="bg-decor-icon" style="bottom: 20%; left: 15%; animation-delay: 2s;"><svg width="14" height="14" viewBox="0 0 24 24" fill="var(--primary-purple)" class="twinkle-star"><path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41L12 0Z"/></svg></div>
                    <div class="bg-decor-icon" style="bottom: 15%; right: 10%; animation-delay: 1.5s;"><svg width="10" height="10" viewBox="0 0 24 24" fill="var(--primary-purple)" class="twinkle-star"><path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41L12 0Z"/></svg></div>
                    <div class="bg-decor-icon" style="top: 50%; left: 5%; animation-delay: 0.5s;"><svg width="6" height="6" viewBox="0 0 24 24" fill="var(--primary-purple)" class="twinkle-star"><path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41L12 0Z"/></svg></div>
                    <div class="bg-decor-icon" style="top: 40%; right: 5%; animation-delay: 2.5s;"><svg width="9" height="9" viewBox="0 0 24 24" fill="var(--primary-purple)" class="twinkle-star"><path d="M12 0L14.59 9.41L24 12L14.59 14.59L12 24L9.41 14.59L0 12L9.41 9.41L12 0Z"/></svg></div>
                    <h2 style="font-size: 3rem; font-weight: 800; margin-bottom: 30px; font-family: 'Bellota', cursive; color: var(--primary-purple); position: relative; z-index: 2;">Любовь к организаторам и гостям — основа всего</h2>
                    <p style="font-size: 22px; color: #4b5563; max-width: 800px; margin: 0 auto; line-height: 1.6; position: relative; z-index: 2;">Каждая функция, каждая кнопка, каждое уведомление — всё это ради того, чтобы вам было удобно, понятно и приятно. Мы задаём тон изменениям<br>в ивент-индустрии по всей стране.</p>
                </div>
            </section>

            <style>
                .bg-decor-icon { position: absolute; pointer-events: none; z-index: 1; }
                .twinkle-star { opacity: 0.4; animation: twinkle 3s infinite ease-in-out; filter: drop-shadow(0 0 5px rgba(99, 91, 255, 0.3)); }
                @keyframes twinkle { 0%, 100% { transform: scale(0.7); opacity: 0.2; } 50% { transform: scale(1.3); opacity: 0.6; } }
            </style>

            <!-- Partners & CTA Section -->
            <section class="about-cta container" style="margin-bottom: 120px; display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                <div class="cta-card" style="background: #1e293b; color: #fff; padding: 60px; border-radius: 60px; display: flex; flex-direction: column; justify-content: space-between; min-height: 500px; transition: all 0.4s cubic-bezier(0.2, 1, 0.3, 1); border: 1px solid rgba(255,255,255,0.05);">
                    <div>
                        <h3 style="font-size: 3.2rem; font-weight: 800; margin-bottom: 25px; font-family: 'Manrope', sans-serif; line-height: 1.1;">Станьте нашим <br><span style="font-family: 'Bellota', cursive; position: relative; display: inline-block;">партнёром<svg style="position: absolute; bottom: -8px; left: 0; width: 100%; height: 12px;" viewBox="0 0 100 12" preserveAspectRatio="none"><path d="M0,10 Q50,0 100,10" stroke="var(--primary-purple)" stroke-width="6" fill="none" stroke-linecap="round"/></svg></span></h3>
                        <p style="font-size: 18px; opacity: 0.7; margin-bottom: 40px; font-family: 'Manrope', sans-serif; line-height: 1.6; max-width: 400px;">Если у вас есть кафе, студия, лофт или база отдыха — и вы хотите принимать мероприятия и новых гостей, вам сюда.</p>
                    </div>
                    <a href="/partners" class="btn-light-purple" style="text-align: center; text-decoration: none; padding: 22px; border-radius: 24px; font-weight: 800; background: #e0e7ff; color: #4f46e5; font-family: 'Manrope', sans-serif; font-size: 18px; transition: all 0.3s ease;">Стать партнёром</a>
                </div>
                <div class="cta-card" style="background: var(--primary-purple); color: #fff; padding: 60px; border-radius: 60px; display: flex; flex-direction: column; justify-content: space-between; min-height: 500px; transition: all 0.4s cubic-bezier(0.2, 1, 0.3, 1); border: 1px solid rgba(255,255,255,0.1);">
                    <div>
                        <h3 style="font-size: 3.2rem; font-weight: 800; margin-bottom: 25px; font-family: 'Manrope', sans-serif; line-height: 1.1;">Стать <br><span style="font-family: 'Bellota', cursive; position: relative; display: inline-block;">клиентом<svg style="position: absolute; bottom: -8px; left: 0; width: 100%; height: 12px;" viewBox="0 0 100 12" preserveAspectRatio="none"><path d="M0,10 Q50,0 100,10" stroke="white" stroke-width="6" fill="none" stroke-linecap="round"/></svg></span></h3>
                        <p style="font-size: 18px; opacity: 0.9; margin-bottom: 40px; font-family: 'Manrope', sans-serif; line-height: 1.6; max-width: 400px;">Хотите проводить мероприятия и находить благодарную аудиторию? Мы поможем вам вырасти.</p>
                    </div>
                    <a href="/auth/register" class="btn-dark" style="text-align: center; text-decoration: none; padding: 22px; border-radius: 24px; font-weight: 800; background: #1e293b; color: #fff; font-family: 'Manrope', sans-serif; font-size: 18px; transition: all 0.3s ease;">Стать организатором</a>
                </div>
            </section>

            <style>
                .cta-card:hover { transform: translateY(-10px) scale(1.01); box-shadow: 0 30px 60px rgba(0,0,0,0.15); }
                .btn-light-purple:hover { background: #fff !important; transform: translateY(-2px); }
                .btn-dark:hover { background: #000 !important; transform: translateY(-2px); }
            </style>

            <!-- Contact Section -->
            <section class="about-contact" style="margin-bottom: 120px; width: 100vw; margin-left: calc(-50vw + 50%); position: relative; overflow: hidden;">
                <div class="cta-profile-box" style="background: var(--primary-purple); padding: 100px 0; color: #fff; position: relative; overflow: hidden;">
                    <!-- Декоративные линии как на главной -->
                    <img src="/images/static/cta-line-top.svg" class="cta-line top" alt="" style="position: absolute; top: 0; left: 0; width: 100%; opacity: 0.3; pointer-events: none;">
