<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Мои мероприятия - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .profile-layout { 
            display: grid; 
            grid-template-columns: 320px 1fr; 
            gap: 30px; 
            padding: 40px 0; 
            align-items: start;
        }
        .profile-sidebar { 
            background: #fff; 
            border-radius: 24px; 
            padding: 20px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.04); 
            position: sticky;
            top: 100px;
        }
        .profile-menu { display: flex; flex-direction: column; gap: 8px; }
        .menu-btn { 
            display: flex; 
            align-items: center; 
            gap: 12px; 
            padding: 14px 20px; 
            border-radius: 16px; 
            border: none; 
            background: none; 
            color: #64748b; 
            font-family: 'Manrope', sans-serif; 
            font-weight: 600; 
            font-size: 15px; 
            cursor: pointer; 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            text-align: left;
            width: 100%;
            box-sizing: border-box;
            text-decoration: none;
        }
        .menu-btn svg {
            width: 20px;
            height: 20px;
            stroke-width: 2px;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .menu-btn:hover { background: #f1f5f9; color: #1e293b; }
        .menu-btn:hover svg {
            transform: scale(1.2) rotate(5deg);
            color: #635bff;
        }
        .menu-btn.active { 
            background: #635bff; 
            color: #fff; 
            box-shadow: 0 4px 12px rgba(99, 91, 255, 0.25); 
        }
        .menu-btn.active svg {
            transform: scale(1.1);
            color: #fff;
        }
        .profile-content { 
            background: #fff; 
            border-radius: 24px; 
            padding: 40px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.04); 
            min-height: 500px;
            box-sizing: border-box;
        }
        .section-title { font-family: 'Manrope', sans-serif; font-size: 28px; font-weight: 800; margin-bottom: 25px; color: #1e293b; }
        
        .events-table { width: 100%; border-collapse: separate; border-spacing: 0 12px; margin-top: -12px; }
        .events-table th { text-align: left; padding: 15px 20px; color: #94a3b8; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }
        .events-table tr { background: #f8fafc; transition: 0.3s; }
        .events-table tr:hover { transform: scale(1.01); box-shadow: 0 5px 15px rgba(0,0,0,0.03); }
        .events-table td { padding: 20px; vertical-align: middle; }
        .events-table td:first-child { border-radius: 16px 0 0 16px; }
        .events-table td:last-child { border-radius: 0 16px 16px 0; }

        .status-badge {
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 32px;
            box-sizing: border-box;
        }

        .btn-action {
            padding: 0 16px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 700;
            text-decoration: none;
            transition: 0.3s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            height: 32px;
            box-sizing: border-box;
            border: none;
            cursor: pointer;
            margin-bottom: 0 !important;
        }
        .btn-view { background: #eeeefd; color: #635bff; }
        .btn-view:hover { background: #635bff; color: #fff; opacity: 1; }
        .btn-participants { background: #635bff; color: #fff; }
        .btn-participants:hover { background: #5249ff; color: #fff; opacity: 1; }
        .btn-action:hover { transform: translateY(-2px); }

        .btn-vk-primary {
            background: #635bff;
            color: #fff;
            padding: 14px 28px;
            border-radius: 100px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            font-family: 'Manrope', sans-serif;
        }
        .btn-vk-primary:hover { 
            background: #5249ff; 
            transform: translateY(-3px); 
            box-shadow: 0 10px 20px rgba(99, 91, 255, 0.2);
        }
        .btn-vk-primary svg {
            transition: transform 0.3s ease;
        }
        .btn-vk-primary:hover svg {
            transform: rotate(90deg) scale(1.1);
        }

        @media (max-width: 992px) { .profile-layout { grid-template-columns: 1fr; } .profile-sidebar { position: static; } }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="container">
        <div class="profile-layout">
            <aside class="profile-sidebar">
                <div class="profile-menu">
                    <a href="/organizer/dashboard" class="menu-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                        Дашборд
                    </a>
                    <a href="/organizer/events" class="menu-btn active">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        Мои мероприятия
                    </a>
                    <a href="/organizer/events/create" class="menu-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        Создать мероприятие
                    </a>
                    <a href="/user/profile?tab=notifications" class="menu-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        Уведомления
                    </a>
                </div>
            </aside>

            <main class="profile-content">
                <% if (events && events.length > 0) { %>
                    <div>
                        <table class="events-table">
                            <thead>
                                <tr>
                                    <th>Название</th>
                                    <th>Дата</th>
                                    <th>Статус</th>
                                    <th>Действия</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% events.forEach(event => { %>
                                    <tr>
                                        <td style="font-weight: 700; color: #1e293b;"><%= event.title %></td>
                                        <td style="color: #64748b;"><%= new Date(event.date).toLocaleDateString('ru-RU') %></td>
                                        <td>
                                            <span class="status-badge status-<%= event.status %>">
                                                <%= event.status === 'approved' ? 'Одобрено' : (event.status === 'rejected' ? 'Отклонено' : 'На модерации') %>
                                            </span>
                                        </td>
                                        <td>
                                            <div style="display: flex; gap: 8px;">
                                                <a href="/events/<%= event.id %>" class="btn-action btn-view">Просмотр</a>
                                                <a href="/organizer/events/<%= event.id %>/participants" class="btn-action btn-participants">Участники</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div style="text-align: center; padding: 60px 20px; background: #f8fafc; border-radius: 24px; border: 2px dashed #e2e8f0;">
                        <div class="empty-img-wrapper" style="margin-bottom: 20px; display: flex; justify-content: center;">
                            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="var(--primary-purple)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" style="animation: float 3s ease-in-out infinite;">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                        </div>
                        <p style="color: #94a3b8; font-size: 16px; font-weight: 600; margin-bottom: 24px;">У вас пока нет созданных мероприятий.</p>
                        <a href="/organizer/events/create" class="btn-vk-primary">
                            Создать мероприятие
                        </a>
                    </div>
                <% } %>
            </main>
        </div>
    </div>

    <style>
        @keyframes float {
            0% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-10px) rotate(5deg); }
            100% { transform: translateY(0px) rotate(0deg); }
        }
    </style>

    <%- include('../partials/footer') %>
</body>
</html>
