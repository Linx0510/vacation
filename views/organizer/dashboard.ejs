<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Панель организатора - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
    <style>
        .profile-layout { 
            display: grid; 
            grid-template-columns: 320px 1fr; 
            gap: 30px; 
            padding: 40px 0; 
            align-items: start;
        }
        .profile-sidebar { 
            background: #fff; 
            border-radius: 24px; 
            padding: 20px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.04); 
            position: sticky;
            top: 100px;
        }
        .profile-menu { display: flex; flex-direction: column; gap: 8px; }
        .menu-btn { 
            display: flex; 
            align-items: center; 
            gap: 12px; 
            padding: 14px 20px; 
            border-radius: 16px; 
            border: none; 
            background: none; 
            color: #64748b; 
            font-family: 'Manrope', sans-serif; 
            font-weight: 600; 
            font-size: 15px; 
            cursor: pointer; 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); 
            text-align: left;
            width: 100%;
            box-sizing: border-box;
            text-decoration: none;
        }
        .menu-btn svg {
            width: 20px;
            height: 20px;
            stroke-width: 2px;
            transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .menu-btn:hover { background: #f1f5f9; color: #1e293b; }
        .menu-btn:hover svg {
            transform: scale(1.2) rotate(5deg);
            color: #635bff;
        }
        .menu-btn.active { 
            background: #635bff; 
            color: #fff; 
            box-shadow: 0 4px 12px rgba(99, 91, 255, 0.25); 
        }
        .menu-btn.active svg {
            transform: scale(1.1);
            color: #fff;
        }
        .profile-content { 
            background: #fff; 
            border-radius: 24px; 
            padding: 40px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.04); 
            min-height: 500px;
            box-sizing: border-box;
            overflow: hidden;
        }
        .section-title { font-family: 'Manrope', sans-serif; font-size: 28px; font-weight: 800; margin-bottom: 25px; color: #1e293b; }
        
        .dashboard-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 40px;
        }
        .stat-card {
            background: #f8fafc;
            padding: 25px;
            border-radius: 20px;
            text-align: center;
            border: 1px solid #f1f5f9;
        }
        .stat-label { font-size: 12px; color: #94a3b8; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
        .stat-value { font-size: 32px; font-weight: 800; color: #1e293b; }

        .proposal-card {
            background: #fff;
            border-radius: 24px;
            border: 1px solid #f1f5f9;
            padding: 30px;
            margin-bottom: 20px;
            transition: all 0.3s ease;
        }
        .proposal-card:hover {
            box-shadow: 0 10px 30px rgba(0,0,0,0.03);
            border-color: #635bff22;
        }
        .proposal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        .proposal-author { font-size: 13px; color: #94a3b8; font-weight: 600; }
        .proposal-date { font-size: 13px; color: #94a3b8; }
        .proposal-title { font-size: 20px; font-weight: 800; color: #1e293b; margin-bottom: 10px; }
        .proposal-desc { color: #64748b; line-height: 1.6; margin-bottom: 20px; font-size: 15px; }
        .proposal-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 20px;
            border-top: 1px solid #f1f5f9;
        }
        .votes-count { color: #635bff; font-weight: 800; font-size: 18px; }
        
        .btn-vk-primary {
            background: #635bff;
            color: #fff;
            padding: 12px 24px;
            border-radius: 14px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            display: inline-block;
        }
        .btn-vk-primary:hover { background: #5249ff; transform: translateY(-2px); }

        /* Flash сообщения */
        .alert-success {
            background: #dcfce7;
            color: #166534;
            padding: 12px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideDown 0.3s ease;
        }
        .alert-error {
            background: #fee2e2;
            color: #991b1b;
            padding: 12px 20px;
            border-radius: 12px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideDown 0.3s ease;
        }
        @keyframes slideDown {
            from { transform: translateY(-20px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        @media (max-width: 992px) { 
            .profile-layout { grid-template-columns: 1fr; } 
            .profile-sidebar { position: static; } 
        }
    </style>
</head>
<body>
    <%- include('../partials/header') %>

    <div class="container">
        <div class="profile-layout">
            <!-- Боковое меню -->
            <aside class="profile-sidebar">
                <div class="profile-menu">
                    <a href="/organizer/dashboard" class="menu-btn active">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="9" x2="21" y2="9"></line><line x1="9" y1="21" x2="9" y2="9"></line></svg>
                        Дашборд
                    </a>
                    <a href="/organizer/events" class="menu-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                        Мои мероприятия
                    </a>
                    <a href="/organizer/events/create" class="menu-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        Создать мероприятие
                    </a>
                    <a href="/user/profile?tab=notifications" class="menu-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                        Уведомления
                    </a>
                </div>
            </aside>

            <!-- Контент -->
            <main class="profile-content">
                <!-- Flash сообщения -->
                <% if (success && success.length > 0) { %>
                    <div class="alert-success">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        <%= success %>
                    </div>
                <% } %>
                <% if (error && error.length > 0) { %>
                    <div class="alert-error">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="12" y1="8" x2="12" y2="12"></line>
                            <line x1="12" y1="16" x2="12.01" y2="16"></line>
                        </svg>
                        <%= error %>
                    </div>
                <% } %>

                <div class="dashboard-stats">
                    <div class="stat-card">
                        <div class="stat-label">Всего мероприятий</div>
                        <div class="stat-value"><%= events.length %></div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">На модерации</div>
                        <div class="stat-value" style="color: #635bff;"><%= events.filter(e => e.status === 'pending').length %></div>
                    </div>
                </div>

                <h2 class="section-title" style="font-size: 22px;">Что хотят видеть пользователи</h2>
                
                <div class="proposals-list">
                    <% if (proposals && proposals.length > 0) { %>
                        <% proposals.forEach(proposal => { %>
                            <article class="proposal-card">
                                <div class="proposal-header">
                                    <span class="proposal-author">От: <%= proposal.email %></span>
                                    <span class="proposal-date"><%= new Date(proposal.created_at).toLocaleDateString('ru-RU') %></span>
                                </div>
                                <h3 class="proposal-title"><%= proposal.title %></h3>
                                <p class="proposal-desc"><%= proposal.description %></p>
                                <div class="proposal-footer">
                                    <span class="votes-count"><%= proposal.votes_count %> голосов</span>
                                    <% if (proposal.status === 'voting' || proposal.status === 'approved') { %>
                                        <form action="/organizer/proposals/take/<%= proposal.id %>" method="POST">
                                            <button type="submit" class="btn-vk-primary" onclick="return confirm('Взять это предложение в работу?')">Взять в работу</button>
                                        </form>
                                    <% } else if (proposal.status === 'in_progress') { %>
                                        <span style="color: #635bff; font-weight: 700; display: flex; align-items: center; gap: 5px;">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                            В работе
                                        </span>
                                    <% } else if (proposal.status === 'completed') { %>
                                        <span style="color: #10b981; font-weight: 700; display: flex; align-items: center; gap: 5px;">
                                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                            Реализовано
                                        </span>
                                    <% } %>
                                </div>
                            </article>
                        <% }) %>
                    <% } else { %>
                        <div style="text-align: center; padding: 40px; background: #f8fafc; border-radius: 24px; border: 2px dashed #e2e8f0; color: #94a3b8; font-weight: 600;">
                            Предложений от пользователей пока нет.
                        </div>
                    <% } %>
                </div>
            </main>
        </div>
    </div>

    <%- include('../partials/footer') %>
</body>
</html>