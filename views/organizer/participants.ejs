<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Участники: <%= event.title %> - Вакация</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bellota:wght@400;700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
</head>
<body class="organizer-page-body">
    <%- include('../partials/header') %>

    <main class="container organizer-page" style="padding: 40px 20px;">
        <div class="profile-header" style="margin-bottom: 30px;">
            <nav class="breadcrumb" style="margin-bottom: 15px; font-size: 0.9rem; color: #64748b;">
                <a href="/organizer/events" style="color: #635bff; text-decoration: none;">Мои мероприятия</a>
                <span style="margin: 0 10px;">/</span>
                <span>Участники</span>
            </nav>
            <h1 style="font-size: 2rem; font-weight: 800; color: #1e293b;"><%= event.title %></h1>
            <p style="color: #64748b;">Список пользователей, которые планируют посетить мероприятие</p>
        </div>

        <div class="profile-content">
            <section class="profile-main" style="width: 100%;">
                <div class="participants-list" style="background: #fff; padding: 30px; border-radius: 24px; border: 1px solid #f1f5f9; box-shadow: 0 10px 30px rgba(0,0,0,0.02);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 25px; position: relative; z-index: 10;">
                        <h2 style="font-size: 1.5rem; font-weight: 700;">Всего участников: <%= participants.length %></h2>
                    </div>

                    <% if (participants && participants.length > 0) { %>
                        <table class="admin-table" style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="text-align: left; border-bottom: 2px solid #f1f5f9;">
                                    <th style="padding: 15px 10px; color: #64748b; font-weight: 600;">Имя Фамилия</th>
                                    <th style="padding: 15px 10px; color: #64748b; font-weight: 600;">Email</th>
                                    <th style="padding: 15px 10px; color: #64748b; font-weight: 600;">Телефон</th>
                                    <th style="padding: 15px 10px; color: #64748b; font-weight: 600;">Дата записи</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% participants.forEach(participant => { %>
                                    <tr style="border-bottom: 1px solid #f1f5f9; transition: background 0.3s;">
                                        <td style="padding: 15px 10px; font-weight: 600; color: #1e293b;">
                                            <%= participant.first_name %> <%= participant.last_name %>
                                        </td>
                                        <td style="padding: 15px 10px; color: #64748b;"><%= participant.email %></td>
                                        <td style="padding: 15px 10px; color: #64748b;"><%= participant.phone || '—' %></td>
                                        <td style="padding: 15px 10px; color: #94a3b8; font-size: 0.9rem;">
                                            <%= new Date(participant.created_at).toLocaleDateString('ru-RU') %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div style="text-align: center; padding: 60px 20px;">
                            <p style="color: #64748b; font-size: 1.1rem;">На это мероприятие пока никто не записался.</p>
                        </div>
                    <% } %>
                </div>
            </section>
        </div>
    </main>

    <%- include('../partials/footer') %>
</body>
</html>
